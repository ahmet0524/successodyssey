---
import { getCollection } from 'astro:content';
const posts = await getCollection('blog', ({ data }) => data.pubDate ? new Date(data.pubDate) <= new Date() : true);
// Tarihe göre sıralamak için:
posts.sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate));
---

<h1>Blog Posts</h1>
<ul>
  {posts.map(post => (
    <li>
      <a href={`/blog/${post.slug}/`}>{post.data.title}</a> — <small>{post.data.pubDate}</small>
    </li>
  ))}
</ul>
