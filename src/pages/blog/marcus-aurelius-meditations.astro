    h3 { font-size: 1.2rem; font-weight: 700; color: #334155; margin: 2rem 0 0.75rem; }
    p { font-size: 1.05rem; line-height: 1.8; color: #374151; margin-bottom: 1.25rem; }
    ul, ol { padding-left: 1.5rem; margin-bottom: 1.25rem; li { font-size: 1.05rem; line-height: 1.8; color: #374151; margin-bottom: 0.5rem; } }
