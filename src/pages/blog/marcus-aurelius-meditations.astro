    .article-header { h1 { color: #f1f5f9; } .article-subtitle { color: #94a3b8; } }
    .table-of-contents { background: #1e293b; h2 { color: #cbd5e1; } }
    .article-body { h2 { color: #f1f5f9; } h3 { color: #e2e8f0; } p, li { color: #cbd5e1; } }
