const author = "Success Odyssey Hub";
const readingTime = 10;

const faqData = [
  {
    question: "Why do some people grow from failure while others are crushed by it?",
    answer: "Research by Carol Dweck on growth vs fixed mindset is the most important framework here. People with a growth mindset interpret failure as information about what needs to improve, while those with a fixed mindset interpret failure as evidence of permanent inadequacy. But mindset is not purely innate — it is shaped by how failure was responded to during development, the narratives one holds about identity, and whether one has developed the psychological skills to process failure constructively. These can all be cultivated deliberately."
  },
  {
    question: "How do the Stoics recommend responding to major setbacks?",
    answer: "The Stoics recommended a two-stage response. First, distinguish between what was within your control (your preparation, effort, choices) and what was outside it (timing, others' decisions, luck). Take full responsibility for the former and release attachment to the latter. Second, apply the 'obstacle is the way' principle — actively look for how the setback creates an opportunity or a forcing function that would not have existed otherwise. Marcus Aurelius wrote: 'The impediment to action advances action. What stands in the way becomes the way.'"
  },
  {
    question: "Is there such a thing as a failure that teaches nothing?",
    answer: "Rarely, if approached with genuine reflection. Even catastrophic failures — businesses that collapse, relationships that end badly, decisions with lasting negative consequences — contain important information about your judgment, your risk assessment, your values, and the systems you operate in. The question is not whether the lesson is available but whether you are in a psychological state to receive it. Defensiveness, shame, and self-blame all block the extraction of lessons. The prerequisite for learning from failure is the willingness to look at it clearly."
  }
];

