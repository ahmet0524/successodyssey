      <Image src={heroImage} alt="Millionaire financial habits and daily wealth-building routines" width={1200} height={630} fetchpriority="high" loading="eager" />
    </figure>
    <nav class="table-of-contents">
      <h2>Table of Contents</h2>
      <ol>
        <li><a href="#introduction">Introduction</a></li>
        <li><a href="#section2">The Pay-Yourself-First Principle</a></li>
        <li><a href="#section3">Multiple Income Streams and Continuous Learning</a></li>
        <li><a href="#how-to-apply">How to Apply These Habits</a></li>
        <li><a href="#misconceptions">Common Misconceptions</a></li>
        <li><a href="#conclusion">Conclusion</a></li>
      </ol>
    </nav>
    <!-- AD 1: display, OUTSIDE article-body -->
