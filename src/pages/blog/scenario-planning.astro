  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  image={heroImage}
  type="article"
  datePublished={datePublished}
  dateModified={dateModified}
  author={author}
  canonicalUrl="https://successodysseyhub.com/blog/scenario-planning"
