const pageKeywords    = "scenario planning, scenario analysis, how to do scenario planning, scenario planning examples, scenario planning business, futures thinking, strategic planning scenarios, best case worst case scenario, multiple scenario analysis, scenario planning technique, planning for uncertainty, strategic foresight";
