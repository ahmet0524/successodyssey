const pageDescription = "Networking done wrong is transactional and ineffective. Learn the psychology of genuine relationship-building — giving first, weak ties, and how to build a network that creates real career leverage.";
const canonicalUrl = "https://successodysseyhub.com/blog/networking-strategy";
