const author        = "Success Odyssey Hub";
const pageTitle     = "Epictetus on Control: The Dichotomy That Changes How You Live";
const pageDescription = "A former slave became antiquity's most powerful philosopher of freedom. Epictetus's dichotomy of control — some things are up to us, others are not — is the most practical idea in all of philosophy.";
const pageKeywords  = "Epictetus control, dichotomy of control Epictetus, Enchiridion Epictetus, Epictetus Stoicism, what is up to us Epictetus, Stoic philosophy control anxiety, Epictetus freedom";
const readingTime   = 10;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Epictetus's dichotomy of control?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Epictetus taught that all things divide into two categories: those 'up to us' (our judgments, desires, aversions, and actions) and those 'not up to us' (body, reputation, property, and external events). Wisdom means focusing exclusively on what is up to you and accepting everything else with equanimity. This is the foundational principle of Stoic practice."
      }
    },
    {
      "@type": "Question",
      "name": "Who was Epictetus?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Epictetus (c. 50–135 CE) was a Greek Stoic philosopher who was born into slavery and lived in Rome. His master deliberately broke one of his legs as a demonstration of power. After being freed, he founded a philosophical school in Nicopolis and became one of antiquity's most influential thinkers. His lectures were recorded by his student Arrian in the Discourses and summarized in the Enchiridion."
      }
    },
    {
      "@type": "Question",
      "name": "How does Epictetus's philosophy apply to modern life?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Epictetus's dichotomy of control maps directly to modern psychology: focusing on controllable factors (effort, attitude, preparation) rather than uncontrollable outcomes reduces anxiety, improves performance, and builds genuine resilience. CBT, sports psychology, and resilience research all reflect his core insight."
      }
    }
  ]
};
