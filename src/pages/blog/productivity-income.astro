const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does productivity directly increase income?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Productivity increases income by increasing your output per hour — the amount of value you create in any given period. Over time, employers and markets reward output rather than presence. A person who produces twice the output with the same hours is worth more, can command higher compensation, can build side income, and can advance faster than one who merely works long hours with modest output."
      }
    },
    {
      "@type": "Question",
      "name": "What is the deep work premium and why does it matter for income?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The deep work premium is the income advantage that accrues to people who can perform sustained, cognitively demanding work without distraction. Cal Newport's research found that the ability to do deep work is becoming increasingly rare while simultaneously becoming more valuable as knowledge-work complexity rises. People who master deep work produce higher-quality output, solve harder problems, and develop skills faster — all of which translate to higher market value."
      }
    },
    {
      "@type": "Question",
      "name": "What role do systems and automation play in productivity-based income growth?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Systems and automation multiply productivity by reducing the time required for routine tasks, enabling you to direct more of your finite cognitive resources toward high-value work. Every recurring task that can be systematized or automated represents a permanent increase in effective hourly output. Over time, the compounding of small systematizations produces dramatic productivity advantages — and corresponding income advantages — over those who handle the same tasks manually each time."
      }
    }
  ]
};
---

<Layout
