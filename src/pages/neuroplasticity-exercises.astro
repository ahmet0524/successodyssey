<script is:inline>
/* ── Reading progress ── */
(function() {
  const fill = document.getElementById('reading-progress');
  if (!fill) return;
  window.addEventListener('scroll', function() {
    const el = document.documentElement;
    const top = el.scrollTop || document.body.scrollTop;
    const height = el.scrollHeight - el.clientHeight;
    fill.style.width = (height > 0 ? (top / height * 100) : 0) + '%';
  }, { passive: true });
})();

/* ── Active sidebar link ── */
(function() {
  const links = document.querySelectorAll('.sb-link, .mob-link');
  const sections = document.querySelectorAll('[id]');
  if (!sections.length) return;
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const id = e.target.id;
        links.forEach(l => {
          l.classList.toggle('active', l.dataset.target === id);
        });
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });
  sections.forEach(s => obs.observe(s));
})();

/* ── Smooth scroll ── */
(function() {
  document.querySelectorAll('.sb-link, .mob-link').forEach(a => {
    a.addEventListener('click', function(e) {
      e.preventDefault();
      const t = document.getElementById(this.dataset.target);
      if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' });
      const menu = document.getElementById('mob-pill-menu');
      if (menu) menu.hidden = true;
      const btn = document.getElementById('mob-pill-toggle');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });
  });
  const btn = document.getElementById('mob-pill-toggle');
  const menu = document.getElementById('mob-pill-menu');
  if (btn && menu) {
    btn.addEventListener('click', function() {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      menu.hidden = open;
    });
  }
})();

/* ── 7-Day Tracker ── */
/* ── DÜZELTME 8: localStorage try/catch + SSR fallback — Googlebot uyumlu ── */
(function() {
  const grid = document.getElementById('tracker-grid');
  const statsEl = document.getElementById('tracker-stats');
  const resetBtn = document.getElementById('tracker-reset');
  if (!grid) return;

  const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const STORAGE_KEY = 'npe-tracker-v1';
  const today = new Date().getDay(); // 0=Sun
  const todayIdx = today === 0 ? 6 : today - 1; // convert to Mon=0

  // ── SSR/Googlebot güvenli storage erişimi
  function load() {
    try {
      if (typeof localStorage === 'undefined' || localStorage === null) {
        return new Array(7).fill(false);
      }
      const raw = localStorage.getItem(STORAGE_KEY);
      return raw ? JSON.parse(raw) : new Array(7).fill(false);
    } catch(e) {
      return new Array(7).fill(false);
    }
  }

  function save(data) {
    try {
      if (typeof localStorage !== 'undefined' && localStorage !== null) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      }
    } catch(e) {
      // localStorage kısıtlıysa sessizce geç
    }
  }

  function render(data) {
    grid.innerHTML = '';
    let completed = 0;
    data.forEach(function(done, i) {
      const day = document.createElement('div');
      day.className = 'tracker-day' + (done ? ' done' : '') + (i === todayIdx && !done ? ' today' : '');
      day.innerHTML = '<span>' + DAYS[i] + '</span>';
      day.addEventListener('click', function() {
        data[i] = !data[i];
        save(data);
        render(data);
      });
      grid.appendChild(day);
      if (done) completed++;
    });
    if (statsEl) {
      statsEl.textContent = completed + ' of 7 days completed this week' + (completed === 7 ? ' 🎉 Perfect week!' : '');
    }
  }

  const data = load();
  render(data);

  if (resetBtn) {
    resetBtn.addEventListener('click', function() {
      const fresh = new Array(7).fill(false);
      save(fresh);
      render(fresh);
    });
  }
})();
</script>