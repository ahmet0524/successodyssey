---
// index.astro
import "../styles/main.scss";
---

<!-- Banner -->
<section class="banner">
  <img src="/src/assets/banner.jpg" alt="Banner" />
</section>

<!-- Kartlar -->
<div class="container">
  <div class="card">
    <img src="/src/assets/card1.jpg" alt="Card 1" />
    <div class="card-content">
      <h3>Başlık 1</h3>
      <p>Açıklama 1</p>
    </div>
  </div>
  <div class="card">
    <img src="/src/assets/card2.jpg" alt="Card 2" />
    <div class="card-content">
      <h3>Başlık 2</h3>
      <p>Açıklama 2</p>
    </div>
  </div>
  <div class="card">
    <img src="/src/assets/card3.jpg" alt="Card 3" />
    <div class="card-content">
      <h3>Başlık 3</h3>
      <p>Açıklama 3</p>
    </div>
  </div>
</div>
