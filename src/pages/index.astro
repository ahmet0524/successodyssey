---
import Layout from "../layouts/Layout.astro";
import Banner from "../components/Banner.astro";
import BlogCard from "../components/BlogCard.astro";
import ProductCard from "../components/ProductCard.astro";
import mentalModelsImage from "../assets/mental-models.webp";
import mentalModelsImages from "../assets/mental-models-best.jpeg";
import successPhilosophyImage from "../assets/success-philosophy.webp";
import stoicWisdomImage from "../assets/stoic-wisdom.webp";
import successMindsetImage from "../assets/success-mindset.webp";
import mentalClarityImage from "../assets/mental-clarity.webp";
import digitalPlannerImage from "../assets/2026-planner.webp";
import synchronicityImage from "../assets/synchronicity-hero.webp";
import wealthAssumption from "../assets/assumption-wealth.webp";
import extremeMindsetImage from "../assets/extreme-mindset-hero.webp";
import dopamineDigitalImage from "../assets/dopamine-digital-hero.webp";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://successodysseyhub.com/#website",
      "url": "https://successodysseyhub.com/",
      "name": "Success Odyssey Hub",
      "description": "Transform your life with proven strategies, mental models, and timeless wisdom",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://successodysseyhub.com/blog?search={search_term_string}",
        "query-input": "required name=search_term_string"
      },
      "inLanguage": "en-US"
    },
    {
      "@type": "Organization",
      "@id": "https://successodysseyhub.com/#organization",
      "name": "Success Odyssey Hub",
      "url": "https://successodysseyhub.com/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://successodysseyhub.com/assets/logo.png",
        "width": 120,
        "height": 120
      },
      "sameAs": [
        "https://twitter.com/successodyssey",
        "https://facebook.com/successodyssey",
        "https://linkedin.com/company/successodyssey"
      ]
    }
  ]
};
---

<Layout
  title="Success Odyssey Hub - Transform Your Life with Proven Strategies"
  description="Science-backed mental models, stoicism, neuroscience and success psychology. 110+ research-driven articles to help you think clearly, build habits, and achieve lasting results."
  keywords="mental models, success psychology, stoicism, neuroscience, productivity, habits, personal development, decision making, self improvement"
>
 <Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <link rel="preload" as="image" href={mentalModelsImage.src} />
</Fragment>

  <!-- Hero Section -->
  <section class="hero" itemscope itemtype="https://schema.org/WPHeader">
    <div class="hero-background"></div>
    <div class="container">
      <div class="hero-content">
        <h1 itemprop="headline">
          Transform Your Life with
          <span class="gradient-text">Proven Strategies</span>
        </h1>
        <p itemprop="description">
          Discover the power of mental models, ancient wisdom, and success philosophy
          to unlock your potential and create lasting change.
        </p>
        <div class="hero-cta">
          <a href="#featured" class="cta-button primary">
            Explore Articles
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/products" class="cta-button secondary">
            View Products
          </a>
        </div>

        <div class="hero-trust">
          <div class="hero-trust-item">
            <span class="trust-number">110+</span>
            <span class="trust-label">In-Depth Articles</span>
          </div>
          <div class="trust-divider"></div>
          <div class="hero-trust-item">
            <span class="trust-number">10K+</span>
            <span class="trust-label">Monthly Readers</span>
          </div>
          <div class="trust-divider"></div>
          <div class="hero-trust-item">
            <span class="trust-number">100%</span>
            <span class="trust-label">Science-Backed</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Banner -->
  <div class="container">
    <Banner />
  </div>

  <!-- Topics Section -->
  <section class="topics-section" aria-labelledby="topics-title">
    <div class="container">
      <div class="section-header">
        <h2 id="topics-title">Explore by Topic</h2>
        <p>Find exactly what you need to grow</p>
      </div>
      <div class="topics-grid">
        <a href="/blog/mental-models-for-success" class="topic-card topic-indigo">
          <div class="topic-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
          </div>
          <div class="topic-info">
            <h3>Mental Models</h3>
            <p>Think more clearly</p>
          </div>
          <svg class="topic-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/blog/time-blocking-method" class="topic-card topic-violet">
          <div class="topic-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="topic-info">
            <h3>Productivity</h3>
            <p>Do more, stress less</p>
          </div>
          <svg class="topic-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/blog/psychology-of-success" class="topic-card topic-rose">
          <div class="topic-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <div class="topic-info">
            <h3>Success Psychology</h3>
            <p>Rewire your mindset</p>
          </div>
          <svg class="topic-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/blog/stoicism" class="topic-card topic-amber">
          <div class="topic-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20M6 20V10l6-8 6 8v10"/><path d="M10 20v-5h4v5"/></svg>
          </div>
          <div class="topic-info">
            <h3>Stoicism</h3>
            <p>Ancient wisdom, modern life</p>
          </div>
          <svg class="topic-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/neuroplasticity" class="topic-card topic-teal">
          <div class="topic-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>
          </div>
          <div class="topic-info">
            <h3>Neuroscience</h3>
            <p>How your brain works</p>
          </div>
          <svg class="topic-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/blog/decision-making-framework" class="topic-card topic-blue">
          <div class="topic-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          </div>
          <div class="topic-info">
            <h3>Decision Making</h3>
            <p>Choose with confidence</p>
          </div>
          <svg class="topic-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/blog/atomic-habits-summary" class="topic-card topic-green">
          <div class="topic-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div class="topic-info">
            <h3>Habits & Discipline</h3>
            <p>Build lasting change</p>
          </div>
          <svg class="topic-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/blog/psychology-money-success" class="topic-card topic-orange">
          <div class="topic-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <div class="topic-info">
            <h3>Money & Success</h3>
            <p>Financial psychology</p>
          </div>
          <svg class="topic-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  <section id="featured" class="featured-section" aria-labelledby="featured-title">
    <div class="container">
      <div class="section-header">
        <h2 id="featured-title">Featured Articles</h2>
        <p>Explore our most popular insights on personal development and success</p>
      </div>

      <div class="cards fade-in">
        <BlogCard
          title="15 Mental Models That Successful People Use to Think Clearly"
          summary="Discover the 15 most powerful mental models used by top performers and billionaires to make better decisions, solve complex problems, and build lasting success."
          image={mentalModelsImage.src}
          link="/blog/mental-models-for-success"
        />
        <BlogCard
          title="Dopamine: The Invisible Chains of the Digital Age"
          summary="Discover how dopamine works at the molecular level, how algorithms exploit your brain, and the science-backed protocol to reclaim your focus."
          image={dopamineDigitalImage.src}
          link="/blog/dopamine-digital-age"
        />
        <BlogCard
          title="Mental Models for Better Decisions"
          summary="Discover powerful thinking frameworks that help you navigate complex problems and make smarter choices in life and business."
          image={mentalModelsImages.src}
          link="/blog/mental-models"
        />
        <BlogCard
          title="The Philosophy of Success"
          summary="Learn timeless principles and daily habits that successful people use to achieve their goals and maintain long-term fulfillment."
          image={successPhilosophyImage.src}
          link="/blog/success-philosophy"
        />
        <BlogCard
          title="Stoic Wisdom for Modern Life"
          summary="Apply ancient Stoic teachings to build resilience, find inner peace, and maintain clarity in our fast-paced modern world."
          image={stoicWisdomImage.src}
          link="/blog/stoicism"
        />
        <BlogCard
          title="Synchronicity: When Meaning Reveals Itself"
          summary="Explore synchronicity through spiritual psychology and modern research. Connect insights from Jung, Frankl, and William James."
          image={synchronicityImage.src}
          link="/blog/synchronicity"
        />
         <BlogCard
          title="The Power of Assumption: Wealth Consciousness"
          summary="Discover Neville Goddard's profound teaching on assumption and wealth consciousness. Learn how to embody prosperity through inner transformation."
          image={wealthAssumption.src}
          link="/blog/assumption-wealth"
        />
        <BlogCard
          title="The Neuroscience of Extreme: Why Obsession Works"
          summary="Discover the brain science behind extreme focus. Learn how neuroplasticity, dopamine, and the RAS create lasting transformation through intensity."
          image={extremeMindsetImage.src}
          link="/blog/extreme-mindset-neuroscience"
        />

      </div>

      <div class="view-all-articles">
        <a href="/blog" class="view-all-button">
          View All Articles
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Digital Products Section -->
  <section class="products-section" aria-labelledby="products-title">
    <div class="container">
      <div class="section-header">
        <h2 id="products-title">Premium Resources</h2>
        <p>Transform your life with our carefully crafted digital products</p>
      </div>

      <div class="cards fade-in">
        <ProductCard
          title="The Success Mindset eBook"
          description="A comprehensive guide to developing the mental frameworks that drive extraordinary results. 150+ pages of actionable strategies."
          price="29.99"
          originalPrice="49.99"
          image={successMindsetImage}
          link="https://gumroad.com/l/success-mindset-ebook"
          badge="Bestseller"
        />
        <ProductCard
          title="Mental Clarity Service"
          description="Personalized 1-on-1 coaching session to identify your mental blocks and create a clear path to your goals."
          price="149.99"
          originalPrice="199.99"
          image={mentalClarityImage}
          link="https://claritymentalhealth.net/"
          badge="Limited"
        />
        <ProductCard
          title="Digital Life Planner"
          description="Interactive Notion template with goal tracking, habit formation, and reflection frameworks. Lifetime updates included."
          price="1.99"
          originalPrice="11.99"
          image={digitalPlannerImage}
          link="https://www.etsy.com/listing/4366750562/digital-planner-2026-fully-hyperlinked"
          badge="New"
        />
      </div>

      <div class="view-all-products">
        <a href="/products" class="view-all-button">
          View All Products
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about-preview" aria-labelledby="about-title">
    <div class="container">
      <div class="about-content">
        <h2 id="about-title">Your Journey to Success Starts Here</h2>
        <p>Success Odyssey combines timeless wisdom with modern insights to help you build a meaningful and successful life. Our carefully curated content focuses on practical strategies that create real, lasting change.</p>
        <div class="features">
          <div class="feature feature-card">
            <div class="feature-icon feature-icon--indigo" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Proven Strategies</h3>
            <p>Evidence-based approaches backed by research and real-world results.</p>
          </div>
          <div class="feature feature-card">
            <div class="feature-icon feature-icon--violet" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Practical Wisdom</h3>
            <p>Actionable insights you can apply immediately to see positive changes.</p>
          </div>
          <div class="feature feature-card">
            <div class="feature-icon feature-icon--teal" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 21V19C16 17.9391 15.5786 16.9217 14.8284 16.1716C14.0783 15.4214 13.0609 15 12 15H5C3.93913 15 2.92172 15.4214 2.17157 16.1716C1.42143 16.9217 1 17.9391 1 19V21M12.5 7C12.5 9.20914 10.7091 11 8.5 11C6.29086 11 4.5 9.20914 4.5 7C4.5 4.79086 6.29086 3 8.5 3C10.7091 3 12.5 4.79086 12.5 7ZM20 8V14M23 11H17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Personal Growth</h3>
            <p>Comprehensive approach to developing both mindset and practical skills.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

<!-- Newsletter Section - DEBUG VERSION -->
<section class="newsletter-section" aria-labelledby="newsletter-title">
  <div class="container">
    <div class="newsletter-wrapper">
      <div class="newsletter-background"></div>

      <div class="newsletter-content">
        <div class="newsletter-icon-wrapper">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>

        <h2 id="newsletter-title" class="newsletter-title">
          Join 10,000+ Success Seekers
        </h2>

        <p class="newsletter-subtitle">
          Get weekly insights, mental models, and actionable strategies delivered straight to your inbox. No spam, just value.
        </p>

        <!-- AJAX Form with Debug Logging -->
        <form
          id="mc-embedded-subscribe-form"
          name="mc-embedded-subscribe-form"
          class="newsletter-form"
          novalidate
        >
          <div class="form-wrapper">
            <div class="email-input-wrapper">
              <svg class="email-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              <label for="mce-EMAIL" class="visually-hidden">Email Address</label>
              <input
                type="email"
                name="EMAIL"
                class="email-input"
                id="mce-EMAIL"
                placeholder="Enter your best email"
                required
                autocomplete="email"
              >
            </div>

            <!-- Honeypot for spam protection -->
            <div style="position: absolute; left: -5000px;" aria-hidden="true">
              <input type="text" name="b_5887c657589cfef5abc0d0a51_8457f8a68e" tabindex="-1" value="">
            </div>

            <button type="submit" name="subscribe" id="mc-embedded-subscribe" class="subscribe-btn">
              <span class="btn-text">Subscribe Free</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </button>
          </div>

          <!-- Response Messages -->
          <div id="mce-responses">
            <div id="mce-error-response" style="display:none;"></div>
            <div id="mce-success-response" style="display:none;"></div>
          </div>

          <!-- Debug Info -->
          <div id="debug-info" style="margin-top: 1rem; padding: 1rem; background: rgba(0,0,0,0.1); border-radius: 8px; font-family: monospace; font-size: 0.85rem; color: white; display: none;"></div>
        </form>

        <div class="newsletter-features">
          <div class="newsletter-feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <span>Free forever</span>
          </div>
          <div class="newsletter-feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <span>Unsubscribe anytime</span>
          </div>
          <div class="newsletter-feature">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
            <span>Double opt-in</span>
          </div>
        </div>

        <div class="stats">
          <div class="stat">
            <div class="stat-number">10K+</div>
            <div class="stat-label">Subscribers</div>
          </div>
          <div class="stat">
            <div class="stat-number">4.9★</div>
            <div class="stat-label">Rating</div>
          </div>
          <div class="stat">
            <div class="stat-number">52</div>
            <div class="stat-label">Weekly Tips</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

</Layout>

<style lang="scss">

/* ========================================
   HERO SECTION
   ======================================== */

.hero {
  position: relative;
  padding: 6rem 0 4rem;
  overflow: hidden;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;

  &-background {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(255,255,255,0.1) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(255,255,255,0.1) 0%, transparent 50%);
    animation: hero-pulse 8s ease-in-out infinite;
  }

  &-content {
    position: relative;
    text-align: center;
    color: white;
    max-width: 900px;
