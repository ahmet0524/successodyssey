---
import Layout from "../../layouts/Layout.astro";

// Direct archive.org PDF link — 100% legal, public domain
const PDF_URL = "https://archive.org/download/ThinkAndGrowRichNapoleonHill_201811/Think%20and%20Grow%20Rich%20-%20Napoleon%20Hill.pdf";

const pageTitle       = "Your Download is Ready — Think and Grow Rich";
const pageDescription = "Download Think and Grow Rich by Napoleon Hill. Your free PDF is ready.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  type="website"
  canonicalUrl="https://successodysseyhub.com/free/thank-you-think-and-grow-rich"
>

<main class="thankyou-page">
  <div class="container">

    <div class="thankyou-card">

      <div class="check-icon">✓</div>
      <h1>You're all set!</h1>
      <p class="subtitle">Thank you for joining. Your free copy of <strong>Think and Grow Rich</strong> is ready to download.</p>

      <a href={PDF_URL} target="_blank" rel="noopener" class="download-btn" download>
        ⬇ Download PDF — Think and Grow Rich
      </a>

      <p class="file-note">PDF · Original 1937 Edition · Public Domain · Free Forever</p>

      <div class="divider"></div>

      <!-- UPSELL: Amazon hardcover -->
      <div class="upsell">
        <p>📖 Want a beautiful hardcover to keep on your desk?</p>
        <a
          href="https://www.amazon.com/dp/1585424331/?tag=successodysse-20"
          target="_blank"
          rel="noopener sponsored"
          class="amazon-btn"
        >
          View on Amazon →
        </a>
        <p class="upsell-note">Affiliate link — we may earn a small commission</p>
      </div>

      <div class="divider"></div>

      <!-- NEXT STEPS -->
      <div class="next-steps">
        <h2>While you read, explore these insights:</h2>
        <div class="article-links">
          <a href="/blog/napoleon-hill-lessons" class="article-link">
            <span class="article-arrow">→</span>
            <div>
              <strong>The 7 Most Powerful Lessons from Napoleon Hill</strong>
              <span>The principles that still apply 90 years later</span>
            </div>
          </a>
          <a href="/blog/think-and-grow-rich" class="article-link" style="display:none"></a>
          <a href="/blog/timeless-success-principles" class="article-link">
            <span class="article-arrow">→</span>
            <div>
              <strong>Timeless Success Principles That Never Go Out of Style</strong>
              <span>From Hill to Buffett — what the greatest minds agreed on</span>
            </div>
          </a>
          <a href="/blog/growth-mindset-vs-fixed" class="article-link">
            <span class="article-arrow">→</span>
            <div>
              <strong>Growth Mindset vs Fixed Mindset</strong>
              <span>The science behind why belief shapes achievement</span>
            </div>
          </a>
          <a href="/blog/visualization-success" class="article-link">
            <span class="article-arrow">→</span>
            <div>
              <strong>The Science of Visualization</strong>
              <span>Why Hill's "burning desire" concept is backed by neuroscience</span>
            </div>
          </a>
        </div>
      </div>

    </div>
  </div>
</main>

</Layout>

<style>
.thankyou-page {
  background: var(--color-bg-secondary);
  min-height: 80vh;
  padding: 5rem 0;
}

.thankyou-card {
  max-width: 640px;
  margin: 0 auto;
  background: var(--color-bg-primary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 3rem;
  text-align: center;
  box-shadow: var(--shadow-lg);
}

.check-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64px;
  height: 64px;
  background: linear-gradient(135deg, #10b981, #059669);
  color: white;
  font-size: 1.75rem;
  border-radius: 50%;
  margin-bottom: 1.5rem;
  font-weight: 700;
}

h1 {
  font-size: 2rem;
  margin-bottom: 0.75rem;
}

.subtitle {
  color: var(--color-text-secondary);
  font-size: 1.05rem;
  margin-bottom: 2rem;
  line-height: 1.6;

  strong { color: var(--color-text-primary); }
}

.download-btn {
  display: inline-block;
  padding: 1rem 2.5rem;
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: #1c1008;
  font-weight: 700;
  font-size: 1.1rem;
  border-radius: 0.6rem;
  text-decoration: none;
  transition: transform 0.2s, box-shadow 0.2s;

  &:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(245,158,11,0.35);
  }
}

.file-note {
  margin-top: 0.75rem;
  font-size: 0.78rem;
  color: var(--color-text-tertiary);
}

.divider {
  border: none;
  border-top: 1px solid var(--color-border);
  margin: 2rem 0;
}

/* ── UPSELL ── */
.upsell {
  p { color: var(--color-text-secondary); margin-bottom: 0.75rem; font-size: 0.95rem; }
}

.amazon-btn {
  display: inline-block;
  padding: 0.65rem 1.75rem;
  background: var(--color-bg-secondary);
  border: 2px solid var(--color-primary);
  color: var(--color-primary);
  border-radius: 0.5rem;
  font-weight: 700;
  text-decoration: none;
  transition: var(--transition);

  &:hover {
    background: var(--color-primary);
    color: white;
  }
}

.upsell-note {
  font-size: 0.72rem !important;
  color: var(--color-text-tertiary) !important;
  margin-top: 0.5rem !important;
}

/* ── NEXT STEPS ── */
.next-steps {
  text-align: left;

  h2 {
    font-size: 1.15rem;
    margin-bottom: 1.25rem;
    text-align: center;
  }
}

.article-links {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.article-link {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 0.9rem 1rem;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  text-decoration: none;
  transition: var(--transition);

  &:hover {
    border-color: var(--color-primary);
    transform: translateX(4px);
  }

  .article-arrow {
    color: var(--color-primary);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  strong {
    display: block;
    color: var(--color-text-primary);
    font-size: 0.9rem;
    margin-bottom: 2px;
  }

  span {
    color: var(--color-text-tertiary);
    font-size: 0.8rem;
  }
}

@media (max-width: 768px) {
  .thankyou-card { padding: 2rem 1.25rem; }
}
</style>
