---
import Layout from "../../layouts/Layout.astro";

const pageTitle       = "Download Think and Grow Rich — Free PDF (Napoleon Hill)";
const pageDescription = "Get the complete Think and Grow Rich PDF by Napoleon Hill — free download. The book that created more millionaires than any other. Enter your email and download instantly.";
const pageKeywords    = "think and grow rich pdf, napoleon hill free download, think and grow rich free, napoleon hill pdf";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  type="website"
  canonicalUrl="https://successodysseyhub.com/free/think-and-grow-rich"
>

<main class="free-page">

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">

        <div class="book-mockup">
          <div class="book-cover-art">
            <div class="book-spine"></div>
            <div class="book-front">
              <p class="book-label">Napoleon Hill</p>
              <h2>Think<br/>and<br/>Grow<br/>Rich</h2>
              <p class="book-year">Original 1937 Edition</p>
            </div>
          </div>
          <div class="book-glow"></div>
        </div>

        <div class="hero-content">
          <span class="badge">FREE DOWNLOAD · Public Domain Classic</span>
          <h1>The Book That Has Created<br/>More Millionaires Than Any Other</h1>
          <p class="hero-sub">
            Napoleon Hill spent <strong>20 years</strong> interviewing 500+ of the world's
            most successful people — from Andrew Carnegie to Henry Ford.
            This is what he discovered.
          </p>

          <ul class="hook-list">
            <li>🧠 The secret Carnegie whispered to Hill — and never spoke of publicly</li>
            <li>🔥 Why 98% of people drift through life without a definite purpose</li>
            <li>💡 The 13 principles shared by every self-made millionaire Hill studied</li>
            <li>⚡ The mastermind principle that multiplies individual intelligence</li>
          </ul>

          <!-- NETLIFY FORM -->
          <form
            name="think-and-grow-rich-leads"
            method="POST"
            action="/free/thank-you-think-and-grow-rich"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="download-form"
          >
            <input type="hidden" name="form-name" value="think-and-grow-rich-leads" />
            <input type="hidden" name="book" value="Think and Grow Rich" />
            <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="form-row">
              <input
                type="email"
                name="email"
                placeholder="Your email address"
                required
                autocomplete="email"
              />
              <button type="submit">
                Download Free PDF →
              </button>
            </div>
            <p class="form-note">No spam. Unsubscribe anytime. We'll also send you our best weekly insights.</p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- QUOTES SECTION -->
  <section class="quotes-section">
    <div class="container">
      <h2>13 Words That Changed Everything</h2>
      <p class="section-sub">These are not motivational phrases. These are principles extracted from studying the lives of the most successful people in American history.</p>

      <div class="quotes-grid">
        <div class="quote-card">
          <span class="quote-num">01</span>
          <h3>Desire</h3>
          <p>"The starting point of all achievement is desire. Keep this constantly in mind. Weak desires bring weak results."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">02</span>
          <h3>Faith</h3>
          <p>"Whatever the mind can conceive and believe, it can achieve."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">03</span>
          <h3>Specialized Knowledge</h3>
          <p>"Knowledge is only potential power. It becomes power only when organized into definite plans of action."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">04</span>
          <h3>The Mastermind</h3>
          <p>"No two minds ever come together without thereby creating a third, invisible, intangible force which may be likened to a third mind."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">05</span>
          <h3>Persistence</h3>
          <p>"Every failure brings with it the seed of an equivalent benefit. Most great people have achieved their greatest success just one step beyond their greatest failure."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">06</span>
          <h3>The Subconscious</h3>
          <p>"The subconscious mind makes no distinction between constructive and destructive thought impulses. It works with the material we feed it."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SECOND CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Read the Book That Started It All</h2>
        <p>Published in 1937. Still the most studied success book in the world.<br/>
        Download the original edition — completely free, no strings attached.</p>
        <form
          name="think-and-grow-rich-leads"
          method="POST"
          action="/free/thank-you-think-and-grow-rich"
          data-netlify="true"
          class="download-form download-form--dark"
        >
          <input type="hidden" name="form-name" value="think-and-grow-rich-leads" />
          <input type="hidden" name="book" value="Think and Grow Rich" />
          <input type="hidden" name="bot-field" />
          <div class="form-row">
            <input type="email" name="email" placeholder="Your email address" required autocomplete="email" />
            <button type="submit">Get Free PDF →</button>
          </div>
        </form>
        <p class="affiliate-note">
          Want a beautiful printed edition?
          <a href="https://www.amazon.com/dp/1585424331/?tag=successodysse-20" target="_blank" rel="noopener sponsored">
            Get the hardcover on Amazon →
          </a>
        </p>
      </div>
    </div>
  </section>

</main>

</Layout>

<style>
.free-page {
  background: var(--color-bg-primary);
}

/* ── HERO ── */
.hero {
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
  padding: 5rem 0 4rem;
  position: relative;
  overflow: hidden;

  &::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(99,102,241,0.15) 0%, transparent 70%);
    border-radius: 50%;
  }
}

.hero-inner {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 1;
}

/* ── BOOK MOCKUP ── */
.book-mockup {
  position: relative;
  display: flex;
  justify-content: center;
}

.book-glow {
  position: absolute;
  inset: -20px;
  background: radial-gradient(circle at center, rgba(245,158,11,0.2) 0%, transparent 70%);
  border-radius: 50%;
  filter: blur(20px);
}

.book-cover-art {
  display: flex;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));
}

.book-spine {
  width: 28px;
  background: linear-gradient(90deg, #7c2d00, #b45309);
  border-radius: 4px 0 0 4px;
  flex-shrink: 0;
}

.book-front {
  width: 180px;
  background: linear-gradient(160deg, #1c1008, #3d1f00, #7c4a00);
  border-radius: 0 6px 6px 0;
  padding: 2rem 1.5rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 260px;
  border: 1px solid rgba(245,158,11,0.3);
  border-left: none;

  h2 {
    font-size: 1.8rem;
    font-weight: 900;
    color: #fbbf24;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }

  .book-label {
    font-size: 0.7rem;
    color: rgba(251,191,36,0.7);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0;
  }

  .book-year {
    font-size: 0.65rem;
    color: rgba(251,191,36,0.5);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
}

/* ── HERO CONTENT ── */
.badge {
  display: inline-block;
  background: rgba(245,158,11,0.15);
  color: #fbbf24;
  border: 1px solid rgba(245,158,11,0.3);
  padding: 0.4rem 1rem;
  border-radius: 2rem;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 1.25rem;
}

.hero-content h1 {
  font-size: 2.2rem;
  color: #fff;
  line-height: 1.2;
  margin-bottom: 1rem;
}

.hero-sub {
  color: rgba(255,255,255,0.7);
  font-size: 1.1rem;
  line-height: 1.6;
  margin-bottom: 1.5rem;

  strong { color: #fbbf24; }
}

.hook-list {
  list-style: none;
  padding: 0;
  margin: 0 0 2rem;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;

  li {
    color: rgba(255,255,255,0.85);
    font-size: 0.95rem;
    padding-left: 0.25rem;
  }
}

/* ── FORM ── */
.download-form .form-row {
  display: flex;
  gap: 0.75rem;
  margin-bottom: 0.5rem;

  input[type="email"] {
    flex: 1;
    padding: 0.9rem 1.2rem;
    border: 2px solid rgba(245,158,11,0.4);
    border-radius: 0.5rem;
    background: rgba(255,255,255,0.08);
    color: #fff;
    font-size: 1rem;
    outline: none;

    &::placeholder { color: rgba(255,255,255,0.4); }
    &:focus { border-color: #fbbf24; background: rgba(255,255,255,0.12); }
  }

  button {
    padding: 0.9rem 1.75rem;
    background: linear-gradient(135deg, #f59e0b, #d97706);
    color: #1c1008;
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 0.2s, box-shadow 0.2s;

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(245,158,11,0.4);
    }
  }
}

.form-note {
  color: rgba(255,255,255,0.4);
  font-size: 0.78rem;
  margin: 0;
}

.hidden { display: none; }

/* ── QUOTES ── */
.quotes-section {
  padding: 5rem 0;
  background: var(--color-bg-secondary);

  h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .section-sub {
    text-align: center;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }
}

.quotes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}

.quote-card {
  background: var(--color-bg-primary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 1.75rem;
  position: relative;
  transition: var(--transition);

  &:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
  }

  .quote-num {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: 2px;
    margin-bottom: 0.5rem;
  }

  h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
  }

  p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    font-style: italic;
    margin: 0;
  }
}

/* ── BOTTOM CTA ── */
.cta-section {
  padding: 5rem 0;
  background: var(--color-bg-primary);
}

.cta-box {
  background: linear-gradient(135deg, #0f172a, #1e1b4b);
  border: 1px solid rgba(99,102,241,0.3);
  border-radius: var(--radius-lg);
  padding: 3.5rem;
  text-align: center;

  h2 { color: #fff; font-size: 1.9rem; margin-bottom: 0.75rem; }
  p { color: rgba(255,255,255,0.65); margin-bottom: 2rem; line-height: 1.7; }
}

.download-form--dark {
  max-width: 500px;
  margin: 0 auto 1.5rem;

  input[type="email"] {
    background: rgba(255,255,255,0.06) !important;
  }
}

.affiliate-note {
  font-size: 0.85rem !important;
  color: rgba(255,255,255,0.4) !important;
  margin: 0 !important;

  a {
    color: #fbbf24;
    text-decoration: none;
    &:hover { text-decoration: underline; }
  }
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .hero-inner {
    grid-template-columns: 1fr;
    gap: 2rem;
    text-align: center;
  }

  .book-mockup { justify-content: center; }
  .hook-list { text-align: left; }

  .download-form .form-row {
    flex-direction: column;
    button { width: 100%; }
  }

  .hero-content h1 { font-size: 1.7rem; }
  .cta-box { padding: 2rem 1.5rem; }
}
</style>
