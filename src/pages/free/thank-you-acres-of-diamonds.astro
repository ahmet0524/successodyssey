---
import Layout from "../../layouts/Layout.astro";
const PDF_URL = "https://archive.org/download/acresofdiamondsl00conw/acresofdiamondsl00conw.pdf";
const pageTitle = "Your Download is Ready — Acres of Diamonds";
const pageDescription = "Download Acres of Diamonds by Russell H. Conwell. Your free PDF is ready.";
---

<Layout title={pageTitle} description={pageDescription} type="website"
  canonicalUrl="https://successodysseyhub.com/free/thank-you-acres-of-diamonds">

<main class="thankyou-page">
  <div class="container">
    <div class="thankyou-card">
      <div class="check-icon" style="background:linear-gradient(135deg,#f97316,#f97316cc);">✓</div>
      <h1>You're all set!</h1>
      <p class="subtitle">Your free copy of <strong>Acres of Diamonds</strong> by <strong>Russell H. Conwell</strong> is ready.</p>
      <a href={PDF_URL} target="_blank" rel="noopener" class="download-btn" style="background:linear-gradient(135deg,#f97316,#f97316cc);" download>
        ⬇ Download PDF — Acres of Diamonds
      </a>
      <p class="file-note">PDF · Public Domain · Free Forever</p>
      <div class="divider"></div>
      <div class="upsell">
        <p>📖 Want a beautiful printed edition to keep on your desk?</p>
        <a href="https://www.amazon.com/dp/1640951369/?tag=successodysse-20" target="_blank" rel="noopener sponsored" class="amazon-btn" style="border-color:#f97316;color:#f97316;&:hover{background:#f97316;color:#fff;}">View on Amazon →</a>
        <p class="upsell-note">Affiliate link — we may earn a small commission</p>
      </div>
      <div class="divider"></div>
      <div class="next-steps">
        <h2>Continue your reading journey:</h2>
        <div class="article-links">
          <a href="/free" class="article-link">
            <span class="article-arrow" style="color:#f97316;">→</span>
            <div><strong>More Free Classic Books</strong><span>Browse our full public domain library</span></div>
          </a>
          <a href="/blog" class="article-link">
            <span class="article-arrow" style="color:#f97316;">→</span>
            <div><strong>Explore the Blog</strong><span>Deep-dives on the ideas in this book and beyond</span></div>
          </a>
        </div>
      </div>
    </div>
  </div>
</main>

</Layout>

<style>
.thankyou-page{background:var(--color-bg-secondary);min-height:80vh;padding:5rem 0;}
.thankyou-card{max-width:600px;margin:0 auto;background:var(--color-bg-primary);border:1px solid var(--color-border);border-radius:var(--radius-lg);padding:3rem;text-align:center;box-shadow:var(--shadow-lg);}
.check-icon{display:inline-flex;align-items:center;justify-content:center;width:64px;height:64px;color:white;font-size:1.75rem;border-radius:50%;margin-bottom:1.5rem;font-weight:700;}
h1{font-size:2rem;margin-bottom:0.75rem;}
.subtitle{color:var(--color-text-secondary);font-size:1.05rem;margin-bottom:2rem;line-height:1.6;strong{color:var(--color-text-primary);}}
.download-btn{display:inline-block;padding:1rem 2.5rem;color:#fff;font-weight:700;font-size:1.1rem;border-radius:0.6rem;text-decoration:none;transition:transform .2s,box-shadow .2s;&:hover{transform:translateY(-3px);box-shadow:0 12px 28px rgba(0,0,0,0.25);}}
.file-note{margin-top:0.75rem;font-size:0.78rem;color:var(--color-text-tertiary);}
.divider{border:none;border-top:1px solid var(--color-border);margin:2rem 0;}
.upsell p{color:var(--color-text-secondary);margin-bottom:0.75rem;font-size:0.95rem;}
.amazon-btn{display:inline-block;padding:0.65rem 1.75rem;background:var(--color-bg-secondary);border:2px solid;border-radius:0.5rem;font-weight:700;text-decoration:none;transition:var(--transition);&:hover{color:#fff!important;}}
.upsell-note{font-size:0.72rem!important;color:var(--color-text-tertiary)!important;margin-top:0.5rem!important;}
.next-steps{text-align:left;h2{font-size:1.1rem;margin-bottom:1.25rem;text-align:center;}}
.article-links{display:flex;flex-direction:column;gap:0.75rem;}
.article-link{display:flex;align-items:center;gap:1rem;padding:0.9rem 1rem;background:var(--color-bg-secondary);border:1px solid var(--color-border);border-radius:var(--radius);text-decoration:none;transition:var(--transition);&:hover{border-color:var(--color-primary);transform:translateX(4px);} .article-arrow{font-size:1.1rem;flex-shrink:0;} strong{display:block;color:var(--color-text-primary);font-size:0.9rem;margin-bottom:2px;} span{color:var(--color-text-tertiary);font-size:0.8rem;}}
@media(max-width:768px){.thankyou-card{padding:2rem 1.25rem;}}
</style>
