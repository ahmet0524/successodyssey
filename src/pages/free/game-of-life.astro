---
import Layout from "../../layouts/Layout.astro";

const pageTitle       = "Download The Game of Life and How to Play It — Free PDF (Florence Scovel Shinn)";
const pageDescription = "Published in 1925, Florence Scovel Shinn was decades ahead of her time. She described life as a game with definite rules — and most people lose simply beca";
const pageKeywords    = "the game of life and how to play it pdf, florence scovel shinn free download, the game of life and how to play it free, florence scovel shinn pdf";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  type="website"
  canonicalUrl="https://successodysseyhub.com/free/game-of-life"
>

<main class="free-page">

  <section class="hero" style="background: linear-gradient(135deg, #1a0a12 0%, #3d0f25 50%, #1a0a12 100%);">
    <div class="container">
      <div class="hero-inner">

        <div class="book-mockup">
          <div class="book-cover-art">
            <div class="book-spine" style="background: linear-gradient(90deg, #ec4899aa, #ec4899);"></div>
            <div class="book-front" style="border-color: #ec489955;">
              <p class="book-label">Florence Scovel Shinn</p>
              <h2 style="color:#ec4899;">The Game of Life and How to Play It</h2>
              <p class="book-year">Original 1925 Edition</p>
            </div>
          </div>
          <div class="book-glow" style="background: radial-gradient(circle, #ec489933 0%, transparent 70%);"></div>
        </div>

        <div class="hero-content">
          <span class="badge" style="background:#ec489922;color:#ec4899;border-color:#ec489944;">FREE DOWNLOAD · Public Domain Classic</span>
          <h1>Life is a game. Here are the rules most people never learn.</h1>
          <p class="hero-sub">Published in 1925, Florence Scovel Shinn was decades ahead of her time. She described life as a game with definite rules — and most people lose simply because they don't know the rules. This book is brief, sharp, and surprisingly practical.</p>
          <ul class="hook-list">
            <li>🎮 Life is a game with specific rules — most people just never learned them</li>
            <li>🧠 Written by a woman in 1925 who understood what most still don't today</li>
            <li>🔥 The law of nonresistance: why fighting your problems makes them worse</li>
            <li>⚡ Read in 2 hours. Applied for a lifetime.</li>
          </ul>

          <form
            name="game-of-life-leads"
            method="POST"
            action="/free/thank-you-game-of-life"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="download-form"
          >
            <input type="hidden" name="form-name" value="game-of-life-leads" />
            <input type="hidden" name="book" value="The Game of Life and How to Play It" />
            <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
            <div class="form-row">
              <input type="email" name="email" placeholder="Your email address" required autocomplete="email" style="border-color:#ec489966;" />
              <button type="submit" style="background:linear-gradient(135deg,#ec4899,#ec4899cc);color:#fff;">Download Free PDF →</button>
            </div>
            <p class="form-note">No spam. Unsubscribe anytime.</p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <section class="quotes-section">
    <div class="container">
      <h2>Key Wisdom From the Book</h2>
      <p class="section-sub">These are not motivational quotes — these are the ideas that have shaped how millions of people think about success, purpose, and living well.</p>
      <div class="quotes-grid">
        <div class="quote-card">
          <span class="quote-num">01</span>
          <h3>Game</h3>
          <p>"Life is a game and we are the players."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">02</span>
          <h3>Word</h3>
          <p>"The object of the game of life is to see clearly one's good and to obliterate all mental pictures of evil."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">03</span>
          <h3>Nonresistance</h3>
          <p>"Nonresistance is an absolute law."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">04</span>
          <h3>Intuition</h3>
          <p>"Intuition is a spiritual faculty and does not explain, but simply points the way."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">05</span>
          <h3>Desire</h3>
          <p>"Every man has within himself the complete pattern of his perfect self."</p>
        </div>
        <div class="quote-card">
          <span class="quote-num">06</span>
          <h3>Faith</h3>
          <p>"Faith and fear cannot exist at the same time."</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-box" style="border-color:#ec489944;">
        <h2>Get Your Free Copy Now</h2>
        <p>Published 1925. Still one of the most powerful books you can read.<br/>Download the original edition — completely free.</p>
        <form
          name="game-of-life-leads"
          method="POST"
          action="/free/thank-you-game-of-life"
          data-netlify="true"
          class="download-form download-form--dark"
        >
          <input type="hidden" name="form-name" value="game-of-life-leads" />
          <input type="hidden" name="book" value="The Game of Life and How to Play It" />
          <input type="hidden" name="bot-field" />
          <div class="form-row">
            <input type="email" name="email" placeholder="Your email address" required autocomplete="email" style="border-color:#ec489966;" />
            <button type="submit" style="background:linear-gradient(135deg,#ec4899,#ec4899cc);color:#fff;">Get Free PDF →</button>
          </div>
        </form>
        <p class="affiliate-note">
          Want a beautiful printed edition?
          <a href="https://www.amazon.com/dp/0875165575/?tag=successodysse-20" target="_blank" rel="noopener sponsored">Get the hardcover on Amazon →</a>
        </p>
      </div>
    </div>
  </section>

</main>
</Layout>

<style>
.free-page { background: var(--color-bg-primary); }
.hero { padding: 5rem 0 4rem; position: relative; overflow: hidden; }
.hero::before { content:''; position:absolute; top:-100px; right:-100px; width:400px; height:400px; background:radial-gradient(circle,#ec489922 0%,transparent 70%); border-radius:50%; }
.hero-inner { display:grid; grid-template-columns:280px 1fr; gap:4rem; align-items:center; position:relative; z-index:1; }
.book-mockup { position:relative; display:flex; justify-content:center; }
.book-glow { position:absolute; inset:-20px; filter:blur(20px); border-radius:50%; }
.book-cover-art { display:flex; position:relative; z-index:1; filter:drop-shadow(0 20px 40px rgba(0,0,0,0.5)); }
.book-spine { width:28px; border-radius:4px 0 0 4px; flex-shrink:0; }
.book-front { width:180px; background:linear-gradient(160deg,#1a0a12,#3d0f25); border-radius:0 6px 6px 0; padding:2rem 1.5rem; display:flex; flex-direction:column; justify-content:space-between; min-height:260px; border:1px solid; border-left:none; h2{font-size:1.6rem;font-weight:900;line-height:1.1;text-transform:uppercase;letter-spacing:1px;margin:0;} .book-label{font-size:0.7rem;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:2px;margin:0;} .book-year{font-size:0.65rem;color:rgba(255,255,255,0.4);margin:0;text-transform:uppercase;letter-spacing:1px;} }
.badge { display:inline-block; padding:0.4rem 1rem; border:1px solid; border-radius:2rem; font-size:0.78rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; margin-bottom:1.25rem; }
.hero-content h1 { font-size:2rem; color:#fff; line-height:1.25; margin-bottom:1rem; }
.hero-sub { color:rgba(255,255,255,0.7); font-size:1rem; line-height:1.6; margin-bottom:1.5rem; }
.hook-list { list-style:none; padding:0; margin:0 0 2rem; display:flex; flex-direction:column; gap:0.6rem; li{color:rgba(255,255,255,0.85);font-size:0.95rem;} }
.download-form .form-row { display:flex; gap:0.75rem; margin-bottom:0.5rem; input[type="email"]{flex:1;padding:0.9rem 1.2rem;border:2px solid;border-radius:0.5rem;background:rgba(255,255,255,0.08);color:#fff;font-size:1rem;outline:none;&::placeholder{color:rgba(255,255,255,0.4);}&:focus{background:rgba(255,255,255,0.12);};} button{padding:0.9rem 1.75rem;border:none;border-radius:0.5rem;font-size:1rem;font-weight:700;cursor:pointer;white-space:nowrap;transition:transform .2s,box-shadow .2s;&:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.3);}} }
.form-note { color:rgba(255,255,255,0.4); font-size:0.78rem; margin:0; }
.hidden { display:none; }
.quotes-section { padding:5rem 0; background:var(--color-bg-secondary); h2{text-align:center;font-size:2rem;margin-bottom:0.75rem;} .section-sub{text-align:center;color:var(--color-text-secondary);max-width:600px;margin:0 auto 3rem;line-height:1.6;} }
.quotes-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:1.5rem; }
.quote-card { background:var(--color-bg-primary); border:1px solid var(--color-border); border-radius:var(--radius-lg); padding:1.75rem; transition:var(--transition); &:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);border-color:#ec4899;} .quote-num{display:block;font-size:0.75rem;font-weight:700;color:#ec4899;letter-spacing:2px;margin-bottom:0.5rem;} h3{font-size:1.1rem;margin-bottom:0.75rem;} p{color:var(--color-text-secondary);font-size:0.9rem;line-height:1.6;font-style:italic;margin:0;} }
.cta-section { padding:5rem 0; }
.cta-box { background:linear-gradient(135deg,#1a0a12,#3d0f25); border:1px solid; border-radius:var(--radius-lg); padding:3.5rem; text-align:center; h2{color:#fff;font-size:1.9rem;margin-bottom:0.75rem;} p{color:rgba(255,255,255,0.65);margin-bottom:2rem;line-height:1.7;} }
.download-form--dark { max-width:500px; margin:0 auto 1.5rem; input[type="email"]{background:rgba(255,255,255,0.06)!important;} }
.affiliate-note { font-size:0.85rem!important; color:rgba(255,255,255,0.4)!important; margin:0!important; a{color:#ec4899;text-decoration:none;&:hover{text-decoration:underline;}} }
@media(max-width:768px) {
  .hero-inner{grid-template-columns:1fr;gap:2rem;text-align:center;}
  .book-mockup{justify-content:center;}
  .hook-list{text-align:left;}
  .download-form .form-row{flex-direction:column;button{width:100%;}}
  .hero-content h1{font-size:1.6rem;}
  .cta-box{padding:2rem 1.5rem;}
}
</style>
