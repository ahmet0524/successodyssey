<style>
.freebies-page { background: var(--color-bg-primary); }

.freebies-hero {
  background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
  padding: 5rem 0 4rem;
  text-align: center;

  .hero-badge {
    display: inline-block;
    background: rgba(99,102,241,0.15);
    color: #818cf8;
    border: 1px solid rgba(99,102,241,0.3);
    padding: 0.4rem 1rem;
    border-radius: 2rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  h1 {
    font-size: 2.5rem;
    color: #fff;
    margin-bottom: 1rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.2;
  }

  .hero-sub {
    color: rgba(255,255,255,0.65);
    font-size: 1.1rem;
    max-width: 620px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
}

.hero-stats {
  display: flex;
  justify-content: center;
  gap: 3rem;

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    strong { font-size: 2rem; font-weight: 800; color: #818cf8; }
    span { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin-top: 0.25rem; }
  }
}

.freebies-grid-section {
  padding: 5rem 0;
  background: var(--color-bg-secondary);
}

.freebies-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.5rem;
}

.freebie-card {
  display: flex;
  gap: 1.25rem;
  background: var(--color-bg-primary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
  text-decoration: none;
  transition: var(--transition);
  align-items: flex-start;

  &:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
}

.freebie-cover {
  width: 72px;
  height: 96px;
  border-radius: 6px;
  border: 1px solid;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;

  .freebie-icon { font-size: 2rem; }
}

.freebie-info {
  flex: 1;
  min-width: 0;

  .freebie-category {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-tertiary);
    display: block;
    margin-bottom: 0.3rem;
  }

  h3 {
    font-size: 1rem;
    color: var(--color-text-primary);
    margin: 0 0 0.2rem;
    line-height: 1.3;
  }

  .freebie-author {
    font-size: 0.78rem;
    color: var(--color-text-tertiary);
    margin: 0 0 0.4rem;
  }

  .freebie-tagline {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    margin: 0 0 0.75rem;
    line-height: 1.4;
  }

  .freebie-cta {
    font-size: 0.82rem;
    font-weight: 700;
  }
}

.freebies-note {
  padding: 2rem 0 3rem;
  text-align: center;
  font-size: 0.85rem;
  color: var(--color-text-tertiary);
  a { color: var(--color-primary); text-decoration: none; &:hover { text-decoration: underline; } }
  strong { color: var(--color-text-secondary); }
}

@media (max-width: 768px) {
  .freebies-hero h1 { font-size: 1.75rem; }
  .hero-stats { gap: 1.5rem; }
  .freebies-grid { grid-template-columns: 1fr; }
}
</style>
