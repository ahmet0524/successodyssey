.mb-label{font-weight:700;font-size:.9rem;color:#1e293b;margin-bottom:.35rem;}
.mb-desc{font-size:.8rem;color:#64748b;line-height:1.5;}
.mb-divider{font-size:1.25rem;color:#c7d2fe;}

/* ── Research box ── */
.research-box{background:#f0f4ff;border:1px solid #c7d2fe;border-radius:12px;padding:1.5rem;margin:1.5rem 0;}
.rb-title{font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#6366f1;margin-bottom:.5rem;}
.research-box p{font-size:.95rem;color:#334155;line-height:1.7;}
.research-box strong{color:#1e293b;}

/* ── Method cards ── */
.method-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.25rem;margin:1.5rem 0;}
.method-card{border-radius:12px;padding:1.5rem;border:1px solid transparent;}
.mc-label{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.75rem;}
