.np-sidebar nav ul{list-style:none;}
.sb-link{display:block;padding:.35rem .5rem;font-size:13px;color:#475569;border-radius:6px;text-decoration:none;transition:all .2s;}
.sb-link:hover,.sb-link.active{background:#e0e7ff;color:#4338ca;}
