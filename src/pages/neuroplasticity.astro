---
// src/pages/neuroplasticity.astro
import Layout from '../layouts/Layout.astro';

const pageTitle = "Neuroplasticity & Strategic Personal Development | Success Odyssey Hub";
const pageDescription = "Discover the science of neuroplasticity — how your brain rewires itself for success. Evidence-based strategies on habit formation, dopamine, BDNF, and peak performance.";
const pageKeywords = "neuroplasticity, brain rewiring, habit formation, dopamine, BDNF, neurogenesis, self-directed neuroplasticity, peak performance, growth mindset, synaptic plasticity, LTP, brain science, personal development neuroscience";
const publishedDate = "2025-01-15T00:00:00Z";
const modifiedDate  = "2025-07-10T00:00:00Z";

const sidebarTopics = [
  { id:"intro",          label:"What Is Neuroplasticity?" },
  { id:"foundations",    label:"Historical Foundations"   },
  { id:"mechanisms",     label:"Biological Mechanisms"    },
  { id:"neurochemistry", label:"Neurochemistry of Success"},
  { id:"habits",         label:"Habit Formation"          },
  { id:"six-steps",      label:"6 Steps to Change"        },
  { id:"principles",     label:"Kleim & Jones Principles" },
  { id:"self-directed",  label:"Self-Directed NP"         },
  { id:"lifestyle",      label:"Lifestyle & Biology"      },
  { id:"simulator",      label:"Interactive Simulator"    },
  { id:"faq",            label:"FAQ"                      },
];

const articleSchema = {
  "@context":"https://schema.org","@type":"Article",
  "headline":"Neuroplasticity & Strategic Personal Development: The Complete Scientific Guide",
  "description":pageDescription,
  "author":{"@type":"Organization","name":"Success Odyssey Hub","url":"https://successodysseyhub.com"},
  "publisher":{"@type":"Organization","name":"Success Odyssey Hub"},
  "datePublished":publishedDate,"dateModified":modifiedDate,
  "mainEntityOfPage":{"@type":"WebPage","@id":"https://successodysseyhub.com/neuroplasticity"},
  "keywords":pageKeywords,"articleSection":"Brain Science","inLanguage":"en-US"
};

const faqSchema = {
  "@context":"https://schema.org","@type":"FAQPage",
  "mainEntity":[
    {"@type":"Question","name":"What is neuroplasticity?","acceptedAnswer":{"@type":"Answer","text":"Neuroplasticity is the brain's ability to reorganize and change its neural connections in response to experience, learning, injury, and environmental stimuli."}},
    {"@type":"Question","name":"How long does it take to rewire the brain?","acceptedAnswer":{"@type":"Answer","text":"Research suggests an average of 66 days to form a stable new neural pathway, ranging from 21 to 254 days depending on complexity and individual factors."}},
    {"@type":"Question","name":"What is BDNF?","acceptedAnswer":{"@type":"Answer","text":"BDNF (Brain-Derived Neurotrophic Factor) promotes new synaptic connections and protects existing neurons. It is dramatically boosted by aerobic exercise, quality sleep, and learning complex new skills."}},
    {"@type":"Question","name":"Can adults grow new brain cells?","acceptedAnswer":{"@type":"Answer","text":"Yes. Adult neurogenesis occurs primarily in the hippocampus throughout life. These new neurons integrate more readily into existing networks, giving them a learning advantage."}}
  ]
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  type="article"
  datePublished={publishedDate}
  dateModified={modifiedDate}
  author="Success Odyssey Hub"
  canonicalUrl="/neuroplasticity"
>
  <slot slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
  </slot>

  <div class="np-wrapper">

    <!-- ══ SIDEBAR ══ -->
    <aside class="np-sidebar" aria-label="Article navigation">
      <div class="sb-inner">
        <div class="sb-head">Brain Science</div>
        <nav>
          <ul>
            {sidebarTopics.map(t => (
              <li>
                <a class="sb-link" href={`#${t.id}`} data-target={t.id}>{t.label}</a>
              </li>
            ))}
          </ul>
        </nav>
        <div class="sb-progress">
          <div class="sb-prog-label">Reading progress</div>
          <div class="sb-prog-track"><div class="sb-prog-fill" id="reading-progress"></div></div>
        </div>
      </div>
    </aside>

    <!-- ══ MOBILE NAV ══ -->
    <div class="mob-pill" id="mob-pill">
      <button class="mob-pill-btn" id="mob-pill-toggle" aria-expanded="false">
        <span id="mob-pill-label">Topics</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
      </button>
      <div class="mob-pill-menu" id="mob-pill-menu" hidden>
        {sidebarTopics.map(t => (
          <a class="mob-link" href={`#${t.id}`} data-target={t.id}>{t.label}</a>
        ))}
      </div>
    </div>

    <!-- ══ MAIN ══ -->
    <main class="np-main">

      <!-- ① INTRO -->
      <section id="intro" class="np-sec">
        <div class="eyebrow">Introduction</div>
        <h1>Neuroplasticity &amp; <span class="grad">Strategic Personal Development</span></h1>
        <p class="lead">Your brain is not fixed hardware — it is shapeable software. Every thought, habit, and decision physically reshapes its architecture. This is neuroplasticity: the biological engine beneath every meaningful transformation.</p>

        <div class="stat-row">
          <div class="stat"><span class="sn">86B</span><span class="sd">Neurons in the human brain</span></div>
          <div class="stat"><span class="sn">100T</span><span class="sd">Synaptic connections capable of change</span></div>
          <div class="stat"><span class="sn">66</span><span class="sd">Average days to form a new neural pathway</span></div>
        </div>

        <blockquote class="bq">
          "Wellness is not just a feeling — it is a neurological structure. Positive habits physically change the architecture of your brain."
          <cite>— Success Odyssey Hub</cite>
        </blockquote>

        <div class="node-stage" id="brain-sim" aria-label="Abstract neural network visualization" role="img">
          <div class="node-label">
            <strong>Neural Connection Model</strong>
            <span>Abstract representation of brain networks</span>
          </div>
        </div>
      </section>

      <!-- ② FOUNDATIONS -->
      <section id="foundations" class="np-sec">
        <div class="eyebrow">Foundations</div>
        <h2>Historical Foundations</h2>
        <p class="body-text">For most of the 20th century, neuroscience held that the adult brain was a fixed, hard-wired machine. The discovery of neuroplasticity overturned this dogma entirely.</p>
        <div class="timeline">
          {[
            {year:"1890", name:"William James", body:"First introduced the concept of neuroplasticity, arguing that behavior and mental processes could modify the nervous system — decades before imaging could confirm it."},
            {year:"1894", name:"Santiago Ramón y Cajal", body:"Described non-pathological structural changes in adult brains. Pioneered the Neuron Doctrine — still the foundation of modern neuroscience."},
            {year:"1949", name:'Donald Hebb — "Hebb\'s Law"', body:'"Neurons that fire together, wire together." This principle remains the single most important rule in the neuroscience of learning and the biological engine of every habit you have ever formed.'},
            {year:"Today", name:"Modern Neuroscience", body:"Advanced fMRI and PET imaging confirms lifelong neuroplasticity, including adult hippocampal neurogenesis. Deliberate brain training is now a validated scientific intervention."},
          ].map(t => (
            <div class="tl-item">
              <div class="tl-yr">{t.year}</div>
              <div class="tl-body"><h3>{t.name}</h3><p>{t.body}</p></div>
            </div>
          ))}
        </div>
      </section>

      <!-- ③ MECHANISMS -->
      <section id="mechanisms" class="np-sec">
        <div class="eyebrow">Mechanisms</div>
        <h2>Biological Mechanisms of Neural Change</h2>
        <p class="body-text">Neuroplasticity spans from molecular protein synthesis to large-scale cortical reorganization. These are the six core processes through which your brain physically changes.</p>
        <div class="grid-3">
          {[
            {tag:"Structural",title:"Synaptogenesis",body:"The formation of new synaptic connections between neurons. Every new skill you practice triggers synaptogenesis in the relevant cortical region."},
            {tag:"Structural",title:"Dendritic Arborization",body:"Neurons grow new dendritic branches to receive more input signals, physically expanding the brain's information-processing capacity."},
            {tag:"Cellular",title:"Neurogenesis",body:"New neurons are born in the hippocampus throughout adulthood. These young cells are more excitable and integrate more readily — giving them a learning advantage."},
            {tag:"Functional",title:"Long-Term Potentiation",body:"Repeated, high-frequency stimulation permanently strengthens synaptic connections. LTP is the cellular basis of memory and skill acquisition."},
            {tag:"Functional",title:"Synaptic Pruning (LTD)",body:"Unused connections are weakened through Long-Term Depression. The brain optimizes itself by clearing inefficient pathways — use it or lose it at the cellular level."},
            {tag:"Speed",title:"Myelination",body:"Repeated practice wraps neural pathways in myelin — a sheath that increases signal speed up to 100×, making skilled behaviors feel effortless and automatic."},
          ].map(m => (
            <article class="card">
              <h3>{m.title}</h3>
              <p>{m.body}</p>
              <span class="tag">{m.tag}</span>
            </article>
          ))}
        </div>
        <div class="callout green">
          <div>
            <strong>Key Insight</strong>
            <p>Old habits are never erased — new and stronger neural pathways are built that override them. This is why consistency outperforms intensity: you're constructing a new neural highway, not demolishing an old one.</p>
          </div>
        </div>
      </section>

      <!-- ④ NEUROCHEMISTRY -->
      <section id="neurochemistry" class="np-sec">
        <div class="eyebrow">Neurochemistry</div>
        <h2>Neurochemistry of Success</h2>
        <p class="body-text">Three neurochemicals act as the primary drivers of neuroplasticity and peak performance. Understanding how to naturally optimize them is the foundation of any serious self-development strategy.</p>
        <div class="nc-stack">
          {[
            {cls:"dopa",title:"Dopamine",role:"Motivation & Reward Architect",body:"Far more than a 'pleasure chemical,' dopamine drives motivation, decision-making, attention, and learning. Released when a behavior succeeds or a reward is anticipated, dopamine strengthens the associated neural pathway — making that behavior more likely to recur. It is the neurochemical engine of the entire habit loop.",tips:["Break goals into small milestones to trigger frequent dopamine pulses","Celebrate micro-wins immediately — delayed reward does not wire the brain","Protect baseline levels by limiting passive dopamine sources (doom scrolling, junk food)"]},
            {cls:"ach",title:"Acetylcholine",role:"Attention & Focus Amplifier",body:"Acetylcholine is the neurochemical gatekeeper of learning. It increases the signal-to-noise ratio in the cortex, helping the brain lock onto relevant stimuli and filter out distraction. Research confirms that without adequate acetylcholine activity, LTP — the cellular mechanism of memory — cannot be triggered. Full attention is chemically required for learning.",tips:["Practice deep work in 90-minute focused blocks","Eliminate all digital interruptions during learning sessions","Consume choline-rich foods daily: eggs, liver, fatty fish"]},
            {cls:"bdnf",title:"BDNF",role:"The Brain's Growth Fertilizer",body:"Brain-Derived Neurotrophic Factor (BDNF) promotes new synaptic connections and protects the health of existing neurons. Often called 'Miracle-Gro for the brain,' BDNF is the single most important molecule for neuroplasticity. Chronic stress and poor sleep suppress it. Aerobic exercise, learning, and quality sleep dramatically increase it.",tips:["150+ minutes of moderate aerobic exercise per week","7–9 hours of quality sleep — this is when BDNF consolidates learning","Continuously learn new complex skills to maintain high BDNF expression"]},
          ].map(nc => (
            <article class={`nc-card ${nc.cls}`}>
              <div class="nc-head"><div><h3>{nc.title}</h3><span class="nc-role">{nc.role}</span></div></div>
              <p>{nc.body}</p>
              <div class="nc-tips"><strong>Optimize It:</strong><ul>{nc.tips.map(t=><li>{t}</li>)}</ul></div>
            </article>
          ))}
        </div>
      </section>

      <!-- ⑤ HABITS -->
      <section id="habits" class="np-sec">
        <div class="eyebrow">Habits</div>
        <h2>The Neuroscience of Habit Formation</h2>
        <p class="body-text">Habits are the brain's energy-saving strategy. As behaviors become automatic, control shifts from the energy-intensive prefrontal cortex to the efficient basal ganglia — freeing cognitive resources for higher-order thinking.</p>
        <div class="habit-loop-box">
          <div class="hl-title">The Neural Habit Loop</div>
          <div class="hl-steps">
            {[
              {n:"01",title:"Cue",body:"A trigger — time, place, emotion, or preceding action — activates the basal ganglia to initiate a stored behavioral sequence.",brain:"Sensory Cortex → Basal Ganglia"},
              {n:"02",title:"Craving",body:"Dopamine is released in the nucleus accumbens in anticipation of the reward, creating the motivational drive to complete the action.",brain:"Nucleus Accumbens (Dopamine)"},
              {n:"03",title:"Routine",body:"The automated behavioral sequence executes with minimal prefrontal involvement, making it feel effortless and largely unconscious.",brain:"Dorsal Striatum → Motor Cortex"},
              {n:"04",title:"Reward",body:"Positive feedback consolidates the loop. The orbitofrontal cortex encodes the value, making future repetition increasingly likely.",brain:"Orbitofrontal Cortex → VTA"},
            ].map(s=>(
              <div class="hl-step">
                <div class="hl-n">{s.n}</div>
                <h4>{s.title}</h4><p>{s.body}</p>
                <span class="hl-brain">{s.brain}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="grid-4">
          {[
            {title:"Start Micro",body:"Begin with the smallest possible version of the habit. The goal is to trigger the loop, not achieve perfection. A 2-minute version beats zero every time."},
            {title:"Swap the Routine",body:"Keep the same cue and reward but replace the routine. This is neurologically the most efficient method — you're redirecting existing wiring."},
            {title:"Stack Habits",body:'"After [current habit], I will [new habit]." This hijacks existing neural pathways as anchors for new behavior.'},
            {title:"Never Miss Twice",body:"Missing one day does not erase the neural pathway — the infrastructure remains. Missing two days weakens the connection. Return immediately."},
          ].map(t=>(
            <div class="tip-card">
              <h4>{t.title}</h4><p>{t.body}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- ⑥ SIX STEPS -->
      <section id="six-steps" class="np-sec">
        <div class="eyebrow">6 Steps</div>
        <h2>6 Steps to Neuroplastic Change</h2>
        <p class="body-text">Building a habit from scratch — or dismantling a harmful one — follows a precise neurological sequence. Click each step to explore its science and application.</p>
        <div class="steps-wrap">
          <div class="steps-tabs" role="tablist">
            {[
              {n:1,label:"Awareness & Diagnosis",amber:false},
              {n:2,label:"Micro Goals (Amygdala-Safe)",amber:false},
              {n:3,label:"Low-Friction Environment",amber:false},
              {n:4,label:"Conscious Repetition",amber:false},
              {n:5,label:"Dopaminergic Reward",amber:false},
              {n:6,label:"Wellness → Achievement",amber:true},
            ].map(s=>(
              <button class={`stab ${s.amber?'amber':''} ${s.n===1?'active':''}`} data-step={s.n} role="tab" aria-selected={s.n===1?"true":"false"} aria-controls={`sp-${s.n}`} id={`st-${s.n}`}>
                <span class="stab-n">{s.n}</span>
                <span>{s.label}</span>
              </button>
            ))}
          </div>
          <div class="steps-panel-area">
            <div class="sp active" id="sp-1" role="tabpanel" aria-labelledby="st-1">
              <div class="sp-badge teal">Step 1</div>
              <h3>Awareness &amp; Diagnosis</h3>
              <p>Change begins by switching off autopilot. The habit you want to change exists as a well-traveled neural highway in your basal ganglia. Without judgment, observe which triggers — stress, boredom, specific times or places — activate this old pathway. You cannot redirect a highway you cannot see.</p>
              <p>This step activates your prefrontal cortex's meta-awareness function, creating a brief window between stimulus and response where change becomes possible.</p>
              <div class="sp-action"><strong>Practice:</strong> Today, simply try to "catch" yourself the moment the old habit begins. No action required — pure observation builds the neural foundation for change.</div>
            </div>
            <div class="sp" id="sp-2" role="tabpanel" aria-labelledby="st-2" hidden>
              <div class="sp-badge teal">Step 2</div>
              <h3>Micro Goals — Bypassing Amygdala Resistance</h3>
              <p>The brain's primitive threat-detection system, the amygdala, interprets large behavioral changes as a threat and generates resistance — experienced as procrastination, fatigue, or sudden apathy. This is a biological defense mechanism, not a character flaw.</p>
              <p>The solution: make the goal ridiculously small. Instead of "meditate for 1 hour," start with "take 1 deep breath consciously." The amygdala does not resist tiny actions.</p>
              <div class="sp-action"><strong>Practice:</strong> Reduce your target behavior to a version so small you genuinely cannot refuse it. The neural pathway is opened by any version of the action.</div>
            </div>
            <div class="sp" id="sp-3" role="tabpanel" aria-labelledby="st-3" hidden>
              <div class="sp-badge teal">Step 3</div>
              <h3>Low-Friction Environment Design</h3>
              <p>Don't rely on willpower — design your environment. Willpower is a finite cognitive resource that depletes throughout the day. Environmental design is permanent and requires zero mental energy to maintain.</p>
              <p>Reduce friction on the desired habit (new neural path): lay out your running shoes the night before, keep healthy food visible. Increase friction on the unwanted habit: hide your phone, delete social media apps, make junk food inconvenient.</p>
              <div class="sp-action"><strong>Practice:</strong> Redesign one physical space today to make your target habit the path of least resistance.</div>
            </div>
            <div class="sp" id="sp-4" role="tabpanel" aria-labelledby="st-4" hidden>
              <div class="sp-badge teal">Step 4</div>
              <h3>Conscious Repetition — Firing the Neurons</h3>
              <p>This is the heart of neuroplasticity. <strong>Frequency matters more than intensity.</strong> Each repetition thickens the myelin sheath around the neural pathway, accelerating signal transmission and making the behavior progressively more automatic.</p>
              <p>The resistance you feel in the early days is your brain physically rewiring itself. It is not a sign of failure — it is the sensation of biological change in progress.</p>
              <div class="sp-action"><strong>Practice:</strong> Don't break the chain. A badly executed day beats a missed day. The neural infrastructure you build is cumulative.</div>
            </div>
            <div class="sp" id="sp-5" role="tabpanel" aria-labelledby="st-5" hidden>
              <div class="sp-badge teal">Step 5</div>
              <h3>Dopaminergic Reward — Sealing the Loop</h3>
              <p>The brain encodes and prioritizes rewarded behaviors. Immediately after completing a micro-action, trigger a positive neurochemical response — a genuine internal acknowledgment, a smile, or a brief physical celebration.</p>
              <p>The timing is critical: delayed rewards do not wire the brain. The dopamine signal must arrive within seconds of the action to be associated with that specific behavior.</p>
              <div class="sp-action"><strong>Practice:</strong> The instant you complete the action, celebrate. Make it genuine — performed enthusiasm does not release the same neurochemical response as real pride.</div>
            </div>
            <div class="sp sp-amber" id="sp-6" role="tabpanel" aria-labelledby="st-6" hidden>
              <div class="sp-badge amber">Success Odyssey Signature Step</div>
              <h3>Wellness → Achievement: The Bridge</h3>
              <p>Pure discipline without psychological wellness leads to burnout. The cortisol released by chronic stress physically damages hippocampal neurons, suppresses BDNF, and atrophies the prefrontal cortex — destroying the very neural infrastructure you are trying to build.</p>
              <p>The <strong>Success Odyssey approach</strong> places psychological wellness as the biological prerequisite for lasting achievement. Self-compassion, gratitude practices, and stress management are neurological interventions — they enlarge the hippocampus and create the optimal environment for learning and growth.</p>
              <p>Build success by <em>healing your mind</em>, not by exhausting it.</p>
              <div class="sp-action amber"><strong>Vision:</strong> Every habit built on genuine psychological wellness lasts exponentially longer than one built on fear, shame, or coercion.</div>
            </div>
          </div>
        </div>
      </section>

      <!-- ⑦ PRINCIPLES -->
      <section id="principles" class="np-sec">
        <div class="eyebrow">Principles</div>
        <h2>The 10 Kleim &amp; Jones Principles</h2>
        <p class="body-text">Researchers Jeffrey Kleim and Theresa Jones identified 10 core principles that govern how the brain rewires itself — the operating rules for deliberate self-transformation.</p>
        <div class="grid-3">
          {[
            {n:"01",title:"Use It or Lose It",body:"Neural circuits that aren't regularly activated progressively weaken. Skills require ongoing practice to maintain their cortical representation."},
            {n:"02",title:"Use It and Improve It",body:"Consistent practice of a specific skill expands the neural territory dedicated to it and increases the efficiency of its processing circuits."},
            {n:"03",title:"Specificity",body:"Plasticity is precisely targeted to the nature of training. To develop a skill, practice that exact skill — transfer effects are limited."},
            {n:"04",title:"Repetition Matters",body:"Inducing durable LTP may require thousands of repetitions. Consistency over months beats intense short-term efforts every time."},
            {n:"05",title:"Intensity Matters",body:"Training must push neural activity above a threshold to trigger lasting change. Passive exposure rarely produces structural plasticity."},
            {n:"06",title:"Timing Matters",body:"Plasticity is time-sensitive. Early intervention after learning yields faster results. Sleep immediately consolidates new neural connections."},
            {n:"07",title:"Salience Matters",body:"The brain prioritizes encoding information that is emotionally meaningful, novel, or directly tied to survival and success."},
            {n:"08",title:"Age Matters",body:"Younger brains exhibit faster plasticity, but adult brains remain highly adaptable — they simply require greater focus and consistency."},
            {n:"09",title:"Transference",body:"Gains in one skill can transfer to related skills sharing overlapping neural networks. Learning music enhances spatial reasoning."},
            {n:"10",title:"Interference",body:"Maladaptive patterns — bad habits or incorrectly learned techniques — actively resist new learning. Unlearning is as important as learning."},
          ].map(p=>(
            <article class="card p-card">
              <span class="p-num">{p.n}</span>
              <h3>{p.title}</h3><p>{p.body}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- ⑧ SELF-DIRECTED -->
      <section id="self-directed" class="np-sec dark-sec">
        <div class="eyebrow light">Self-Direction</div>
        <h2 class="light-h">Self-Directed Neuroplasticity</h2>
        <p class="body-text light-p">Self-Directed Neuroplasticity (SDN) is the deliberate, conscious practice of shaping your brain's architecture toward your chosen outcomes — becoming the architect of your mind, not its passive inhabitant.</p>
        <div class="grid-3">
          {[
            {title:"Mental Rehearsal & Visualization",body:"The brain cannot fully distinguish between a vividly imagined and a real experience. During mental rehearsal, the same neural networks activated during physical practice are engaged. Elite athletes, surgeons, and executives use this technique to pre-wire their brains for high-stakes performance — reducing reaction time and decision errors before the real moment arrives.",action:"Spend 10 minutes daily rehearsing a key skill or challenge in first-person perspective. Engage all senses. Pair with physical practice for maximum neuroplastic effect."},
            {title:"Mindfulness & Meditation",body:"Consistent mindfulness practice increases gray matter density in the prefrontal cortex (rational decision-making) and measurably reduces the size and reactivity of the amygdala (fear and stress responses). The result: you respond to challenges with deliberate reason instead of automatic emotional reaction.",action:"Begin with 10 minutes of focused breathing daily. Consistency over 8 weeks produces measurable structural brain changes in most published studies."},
            {title:"Deliberate Practice & the Flow Zone",body:"There is an inverted-U relationship between cognitive load and neuroplasticity. Too easy and the brain stays in autopilot. Too hard and the system overloads. The optimal zone, just beyond current ability, maximizes the neurochemical cocktail that accelerates neural rewiring.",action:"Identify the skill ceiling in your domain and consistently work 1–2 levels above your comfort zone with focused, corrective feedback loops."},
          ].map(s=>(
            <div class="sdnp-card">
              <h3>{s.title}</h3><p>{s.body}</p>
              <div class="sdnp-act"><strong>Practice:</strong> {s.action}</div>
            </div>
          ))}
        </div>
      </section>

      <!-- ⑨ LIFESTYLE -->
      <section id="lifestyle" class="np-sec">
        <div class="eyebrow">Lifestyle</div>
        <h2>Lifestyle &amp; Biology</h2>
        <p class="body-text">Neural rewiring is an energetically expensive biological process. These lifestyle pillars determine whether your brain has the raw materials and cellular environment to change.</p>
        <div class="lifestyle-stack">
          {[
            {title:"Sleep: The Neural Architect",body:"Sleep is neuroplasticity's most active phase. During slow-wave sleep, the brain consolidates the day's learning into long-term memory through synaptic homeostasis. The glymphatic system activates — flushing toxic metabolic waste and misfolded proteins. Chronic sleep deprivation suppresses BDNF and impairs both learning and decision-making.",tips:["7–9 hours nightly","Consistent sleep schedule","No screens 1hr before bed"]},
            {title:"Exercise: The BDNF Trigger",body:"Aerobic exercise is the single most powerful tool for boosting BDNF levels naturally. Physical activity simultaneously increases hippocampal blood flow, promotes neurogenesis, reduces cortisol, and improves working memory and executive function. A single 20-minute run can measurably improve cognitive performance for hours afterward.",tips:["150+ min/week moderate cardio","Resistance training 2×/week","Daily movement breaks"]},
            {title:"Nutrition: Neural Building Blocks",body:"The brain is 60% fat — and its plasticity depends on the quality of dietary fats consumed. Omega-3 fatty acids (EPA and DHA) are incorporated directly into neuronal membranes, increasing flexibility and signal conductance. Antioxidants neutralize oxidative stress that damages synaptic connections. Refined sugars and processed foods promote neuroinflammation.",tips:["Omega-3 rich foods daily","Antioxidant-rich diet","Minimize refined sugars"]},
          ].map(l=>(
            <article class="life-card">
              <div>
                <h3>{l.title}</h3><p>{l.body}</p>
                <div class="pills">{l.tips.map(t=><span class="pill">{t}</span>)}</div>
              </div>
            </article>
          ))}
        </div>
        <div class="callout red">
          <div>
            <strong>The #1 Enemy of Neuroplasticity: Chronic Stress</strong>
            <p>Chronically elevated cortisol physically damages hippocampal neurons, suppresses BDNF, and atrophies the prefrontal cortex. Stress management is not a luxury — it is a biological prerequisite for brain change. No amount of deliberate practice overcomes a chronically cortisol-flooded brain.</p>
          </div>
        </div>
      </section>

      <!-- ⑩ SIMULATOR -->
      <section id="simulator" class="np-sec">
        <div class="eyebrow">Interactive</div>
        <h2>Neural Habit Strength Simulator</h2>
        <p class="body-text">Simulate what happens in your brain as you repeat a new behavior. Watch the new neural pathway grow stronger while the old habit weakens through disuse. Each click represents one day of consistent practice.</p>
        <div class="sim-box">
          <div class="chart-wrap"><canvas id="habitChart" role="img" aria-label="Line chart showing new habit strength increasing and old habit decreasing over time"></canvas></div>
          <div class="sim-ctrl">
            <div>
