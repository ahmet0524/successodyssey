<script>
/* ── Sidebar active tracking ── */
(function(){
  const links = document.querySelectorAll('.sb-link, .mob-link');
  const fill  = document.getElementById('reading-progress');
  const pilLbl = document.getElementById('mob-pill-label');
  const map: Record<string, Element> = {};
  links.forEach(l => { map[(l as HTMLElement).dataset.target!] = l; });

  function setActive(id: string) {
    links.forEach(l => l.classList.remove('active'));
    if (map[id]) map[id].classList.add('active');
    if (pilLbl && map[id]) {
      pilLbl.textContent = map[id].textContent?.trim() || 'Topics';
    }
  }

  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) setActive(e.target.id); });
  }, { rootMargin: '-15% 0px -60% 0px' });

  document.querySelectorAll('.np-sec[id]').forEach(s => obs.observe(s));

  window.addEventListener('scroll', () => {
    if (!fill) return;
    const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
    (fill as HTMLElement).style.width = Math.min(100, pct * 100) + '%';
  }, { passive: true });

  links.forEach(a => {
    a.addEventListener('click', e => {
      e.preventDefault();
      const t = document.getElementById((a as HTMLElement).dataset.target!);
      if (t) t.scrollIntoView({ behavior: 'smooth', block: 'start' });
      const menu = document.getElementById('mob-pill-menu');
      if (menu) menu.hidden = true;
      const btn = document.getElementById('mob-pill-toggle');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });
  });

  const btn  = document.getElementById('mob-pill-toggle');
  const menu = document.getElementById('mob-pill-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!open));
      (menu as HTMLElement).hidden = open;
    });
  }
})();

/* ── 6-Step tab switcher ── */
(function(){
  const tabs   = document.querySelectorAll('.stab');
  const panels = document.querySelectorAll('.sp');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const step = (tab as HTMLElement).dataset.step;
      tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
      panels.forEach(p => { p.classList.remove('active'); (p as HTMLElement).hidden = true; });
      tab.classList.add('active');
      tab.setAttribute('aria-selected','true');
      const panel = document.getElementById('sp-' + step);
      if (panel) { panel.classList.add('active'); panel.hidden = false; }
    });
  });
})();

/* ── Neural node animation ── */
(function(){
  const stage = document.getElementById('brain-sim');
  if (!stage) return;
  const NUM = 7;
  const nodes: HTMLElement[] = [];

  for (let i = 0; i < NUM; i++) {
    const n = document.createElement('div');
    n.className = 'nn-node';
    n.style.left = (10 + Math.random() * 78) + '%';
    n.style.top  = (10 + Math.random() * 62) + '%';
    stage.appendChild(n);
    nodes.push(n);
  }

  const lines: { el: HTMLElement; a: HTMLElement; b: HTMLElement }[] = [];
  for (let i = 0; i < nodes.length; i++) {
    for (let j = i + 1; j < nodes.length; j++) {
      if (Math.random() > 0.45) {
        const l = document.createElement('div');
        l.className = 'nn-line';
        stage.appendChild(l);
        lines.push({ el: l, a: nodes[i], b: nodes[j] });
      }
    }
  }

  function posLine(item: { el: HTMLElement; a: HTMLElement; b: HTMLElement }) {
    const r  = stage!.getBoundingClientRect();
    const ra = item.a.getBoundingClientRect();
    const rb = item.b.getBoundingClientRect();
    const x1 = ra.left - r.left + 6, y1 = ra.top - r.top + 6;
    const x2 = rb.left - r.left + 6, y2 = rb.top - r.top + 6;
    const len = Math.sqrt((x2-x1)**2 + (y2-y1)**2);
    const ang = Math.atan2(y2-y1, x2-x1) * 180 / Math.PI;
    item.el.style.width = len + 'px';
    item.el.style.left  = x1 + 'px';
    item.el.style.top   = y1 + 'px';
    item.el.style.transform = `rotate(${ang}deg)`;
  }

  setTimeout(() => lines.forEach(posLine), 250);

  function drift() {
    nodes.forEach(n => {
      n.style.left = Math.max(5, Math.min(90, parseFloat(n.style.left) + (Math.random() - 0.5) * 3)) + '%';
      n.style.top  = Math.max(5, Math.min(80, parseFloat(n.style.top)  + (Math.random() - 0.5) * 3)) + '%';
    });
    requestAnimationFrame(() => lines.forEach(posLine));
  }

  setInterval(drift, 2200);
})();

/* ── Chart.js Habit Simulator ── */
document.addEventListener('DOMContentLoaded', function() {
  const canvas = document.getElementById('habitChart') as HTMLCanvasElement | null;
  if (!canvas) return;

  function init() {
    if (typeof (window as any).Chart === 'undefined') { setTimeout(init, 300); return; }
    const Chart = (window as any).Chart;
    const ctx = canvas!.getContext('2d');
    let days = [1], nh = [8], oh = [92], day = 1;

    const chart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: days,
        datasets: [
          { label: 'New Habit — Neural Pathway Strength (%)', data: nh, borderColor: '#0f766e', backgroundColor: 'rgba(15,118,110,.08)', borderWidth: 3, tension: .4, fill: true, pointRadius: 4, pointBackgroundColor: '#0f766e' },
          { label: 'Old Habit — Pathway Weakening (%)', data: oh, borderColor: '#d97706', borderWidth: 2.5, borderDash: [6,4], tension: .4, fill: false, pointRadius: 3, pointBackgroundColor: '#d97706' }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false, animation: { duration: 450 },
        scales: {
          y: { beginAtZero: true, max: 100, ticks: { callback: (v: number) => v + '%', color: '#6b7280', font: { size: 11 } }, grid: { color: '#f3f4f6' }, title: { display: true, text: 'Connection Strength (%)', color: '#9ca3af', font: { size: 11 } } },
          x: { ticks: { color: '#6b7280', font: { size: 11 } }, grid: { color: '#f9fafb' }, title: { display: true, text: 'Day / Repetition', color: '#9ca3af', font: { size: 11 } } }
        },
        plugins: { legend: { position: 'top', labels: { usePointStyle: true, padding: 18, color: '#374151', font: { size: 11 } } }, tooltip: { mode: 'index', intersect: false } }
      }
    });

    const statusEl = document.getElementById('sim-status')!;
    const ctrEl    = document.getElementById('day-counter')!;

    document.getElementById('btn-fire')!.addEventListener('click', () => {
      if (day >= 30) { alert('30 repetitions reached. The neural pathway is now strongly myelinated — the habit operates largely on autopilot.'); return; }
      day++;
      days.push(day);
      const ln = nh[nh.length - 1], lo = oh[oh.length - 1];
      nh.push(Math.min(100, ln + (100 - ln) * 0.14 + Math.random() * 1.4));
      oh.push(Math.max(0, lo - lo * 0.11 - Math.random() * 1.4));
      chart.update();
      ctrEl.textContent = String(day);
      if (day < 7)       { statusEl.textContent = 'Resistance Phase — Keep going!'; statusEl.className = 'sim-badge building'; }
      else if (day < 21) { statusEl.textContent = 'Wiring Phase — Connections forming'; statusEl.className = 'sim-badge wiring'; }
      else               { statusEl.textContent = 'Automation Phase'; statusEl.className = 'sim-badge automated'; }
    });

    document.getElementById('btn-reset')!.addEventListener('click', () => {
      day = 1; days.length = 0; days.push(1);
      nh.length = 0; nh.push(8); oh.length = 0; oh.push(92);
      chart.update();
      ctrEl.textContent = '1';
      statusEl.textContent = 'Starting Phase'; statusEl.className = 'sim-badge starting';
    });
  }

  init();
});
</script>