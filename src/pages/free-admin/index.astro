<style>
.admin-page { background: var(--color-bg-secondary); min-height:100vh; padding:3rem 0; }
.admin-header { margin-bottom:2rem; h1{margin-bottom:0.5rem;} p{color:var(--color-text-secondary);margin-bottom:1.5rem;} }
.admin-links { display:flex; gap:1rem; flex-wrap:wrap; }
.admin-btn { padding:0.6rem 1.25rem; background:var(--color-primary); color:#fff; border-radius:var(--radius); text-decoration:none; font-weight:600; font-size:0.9rem; transition:var(--transition); &:hover{opacity:0.85;} }
.admin-btn--outline { background:transparent; border:2px solid var(--color-primary); color:var(--color-primary); }
.admin-stats { display:flex; gap:2rem; margin-bottom:2rem; flex-wrap:wrap; }
.admin-stat { background:var(--color-bg-primary); border:1px solid var(--color-border); border-radius:var(--radius); padding:1.25rem 2rem; text-align:center; strong{display:block;font-size:2rem;font-weight:800;color:var(--color-primary);} span{font-size:0.85rem;color:var(--color-text-tertiary);} small{display:block;font-size:0.75rem;} }
.admin-table-wrap { overflow-x:auto; margin-bottom:3rem; }
.admin-table { width:100%; border-collapse:collapse; background:var(--color-bg-primary); border-radius:var(--radius-lg); overflow:hidden; border:1px solid var(--color-border); thead{background:var(--color-bg-tertiary);} th{padding:0.9rem 1rem;text-align:left;font-size:0.82rem;text-transform:uppercase;letter-spacing:0.5px;color:var(--color-text-secondary);border-bottom:1px solid var(--color-border);} td{padding:0.9rem 1rem;border-bottom:1px solid var(--color-border);font-size:0.88rem;a{color:var(--color-primary);text-decoration:none;font-weight:500;&:hover{text-decoration:underline;}} small{color:var(--color-text-tertiary);} tr:last-child td{border-bottom:none;} } }
.status-dot { display:inline-block; width:8px; height:8px; border-radius:50%; margin-right:6px; }
.admin-instructions { background:var(--color-bg-primary); border:1px solid var(--color-border); border-radius:var(--radius-lg); padding:2rem; h2{font-size:1.1rem;margin-bottom:1rem;} ol{padding-left:1.5rem;line-height:2;color:var(--color-text-secondary);} code{background:var(--color-bg-tertiary);padding:0.1rem 0.4rem;border-radius:4px;font-size:0.85rem;} a{color:var(--color-primary);} }
.template-box { background:var(--color-bg-secondary); border-left:4px solid var(--color-primary); border-radius:0 var(--radius) var(--radius) 0; padding:1.25rem 1.5rem; margin-top:1rem; p{color:var(--color-text-secondary);line-height:1.8;margin:0;font-size:0.9rem;} }
</style>
