---
import Layout from "../layouts/Layout.astro";

const pageTitle = "The Identity Upgrade — YouTube Channel | Success Odyssey Hub";
const pageDescription = "Watch The Identity Upgrade on YouTube — videos on Jungian psychology, manifestation, identity transformation, neuroscience, and the philosophy of personal success. 22 free videos.";
const pageKeywords = "The Identity Upgrade YouTube, Carl Jung manifestation, identity transformation videos, success psychology YouTube, neuroscience personal development channel";

// Featured video + manually curated list
// Thumbnails are free from YouTube's CDN — no API needed
const featuredVideo = {
  id: "NAWA_7N90B4",
  title: "Carl Jung's Hidden Manifestation Method (Change Your Reality Fast)",
  description: "Discover Carl Jung's profound psychological framework for transformation. Learn how the unconscious mind shapes your reality and how to deliberately reprogram your identity for lasting success.",
  category: "Psychology"
};

// Add more video IDs here as you collect them
const videos = [
  { id: "NAWA_7N90B4", title: "Carl Jung's Hidden Manifestation Method", category: "Psychology" },
  // Add more: { id: "VIDEO_ID", title: "Video Title", category: "Category" },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  type="website"
  canonicalUrl="https://successodysseyhub.com/youtube"
>

  <!-- Channel Hero -->
  <section class="yt-hero">
    <div class="container">
      <div class="channel-header">
        <div class="channel-avatar">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="white">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
            <polygon points="9.545,15.568 15.818,12 9.545,8.432" fill="#FF0000"/>
          </svg>
        </div>
        <div class="channel-info">
          <span class="channel-label">YouTube Channel</span>
          <h1>The Identity Upgrade</h1>
          <p class="channel-tagline">Psychology · Manifestation · Identity Transformation · Neuroscience</p>
          <div class="channel-meta">
            <span class="meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 10l4.553-2.069A1 1 0 0121 8.87v6.26a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/></svg>
              22 Videos
            </span>
            <span class="meta-item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
              Free Content
            </span>
          </div>
        </div>
        <div class="channel-cta">
          <a href="https://www.youtube.com/@TheIdentityUpgrade?sub_confirmation=1" target="_blank" rel="noopener" class="btn-subscribe">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><polygon points="9.545,15.568 15.818,12 9.545,8.432" fill="red"/></svg>
            Subscribe on YouTube
          </a>
          <a href="https://www.youtube.com/@TheIdentityUpgrade/videos" target="_blank" rel="noopener" class="btn-view-all">
            View All 22 Videos →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <div class="yt-stats-strip">
    <div class="container">
      <div class="yt-stats">
        <div class="yt-stat">
          <span class="ys-num">22</span>
          <span class="ys-lbl">Free Videos</span>
        </div>
        <div class="yt-div"></div>
        <div class="yt-stat">
          <span class="ys-num">100%</span>
          <span class="ys-lbl">Free to Watch</span>
        </div>
        <div class="yt-div"></div>
        <div class="yt-stat">
          <span class="ys-num">Jung</span>
          <span class="ys-lbl">Psychology Based</span>
        </div>
        <div class="yt-div"></div>
        <div class="yt-stat">
          <span class="ys-num">🎯</span>
          <span class="ys-lbl">Identity-Focused</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Featured Video -->
  <section class="featured-video-section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">🎬 Featured Video</span>
        <h2>Start Here</h2>
        <p>One of our most-watched videos — a deep dive into Carl Jung's psychology of transformation.</p>
      </div>

      <div class="featured-layout">
        <div class="video-embed-wrap">
          <div class="video-embed">
            <iframe
              src={`https://www.youtube.com/embed/${featuredVideo.id}?rel=0&modestbranding=1`}
              title={featuredVideo.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <div class="featured-info">
          <span class="video-category">{featuredVideo.category}</span>
          <h3>{featuredVideo.title}</h3>
          <p>{featuredVideo.description}</p>

          <div class="video-topics">
            <span class="vtag">Carl Jung</span>
            <span class="vtag">Manifestation</span>
            <span class="vtag">Identity</span>
            <span class="vtag">Unconscious Mind</span>
            <span class="vtag">Reality</span>
          </div>

          <a href={`https://www.youtube.com/watch?v=${featuredVideo.id}`} target="_blank" rel="noopener" class="btn-watch">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Watch on YouTube
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What the Channel Covers -->
  <section class="channel-topics-section">
    <div class="container">
      <div class="section-header">
        <span class="section-badge">📚 What You'll Learn</span>
        <h2>Topics Covered on the Channel</h2>
        <p>The Identity Upgrade explores the intersection of psychology, neuroscience, and ancient philosophy to help you transform at the identity level.</p>
      </div>

      <div class="topics-cards">
        <div class="topic-card-yt">
          <div class="tc-icon tc-jung">🧠</div>
          <h3>Jungian Psychology</h3>
          <p>Carl Jung's archetypes, shadow work, the collective unconscious, and how they shape your identity and manifest your reality.</p>
        </div>
        <div class="topic-card-yt">
          <div class="tc-icon tc-neuro">⚡</div>
          <h3>Neuroscience of Change</h3>
          <p>How neuroplasticity, dopamine loops, and the reticular activating system work together to make identity transformation neurologically real.</p>
        </div>
        <div class="topic-card-yt">
          <div class="tc-icon tc-manifest">✨</div>
          <h3>Manifestation & Reality</h3>
          <p>Evidence-based exploration of how belief systems, self-concept, and subconscious programming shape what you attract and achieve.</p>
        </div>
        <div class="topic-card-yt">
          <div class="tc-icon tc-stoic">🏛️</div>
          <h3>Philosophy & Stoicism</h3>
          <p>Ancient wisdom from Marcus Aurelius, Epictetus, and Seneca applied to modern identity challenges and personal transformation.</p>
        </div>
        <div class="topic-card-yt">
          <div class="tc-icon tc-habit">🔄</div>
          <h3>Identity-Based Habits</h3>
          <p>Why behavior change fails without identity change first — and how to reprogram your self-concept to make success inevitable.</p>
        </div>
        <div class="topic-card-yt">
          <div class="tc-icon tc-success">🎯</div>
          <h3>Success Psychology</h3>
          <p>The mental models and psychological patterns that separate high-achievers — and how to install them through deliberate identity work.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="yt-cta-section">
    <div class="container">
      <div class="yt-cta-card">
        <div class="yt-cta-content">
          <div class="yt-logo-big">
            <svg width="52" height="52" viewBox="0 0 24 24" fill="white"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><polygon points="9.545,15.568 15.818,12 9.545,8.432" fill="#FF0000"/></svg>
          </div>
          <h2>22 Free Videos Waiting for You</h2>
          <p>Subscribe to The Identity Upgrade and get notified every time a new video drops. New episodes on psychology, neuroscience, and identity transformation every week.</p>
          <div class="cta-buttons">
            <a href="https://www.youtube.com/@TheIdentityUpgrade?sub_confirmation=1" target="_blank" rel="noopener" class="btn-subscribe-big">
              Subscribe Free — No Cost
            </a>
            <a href="/blog" class="btn-read-more">
              Read the Articles →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style lang="scss">

/* ===== HERO ===== */
.yt-hero {
  background: linear-gradient(135deg, #0f0f0f 0%, #1a1a2e 50%, #16213e 100%);
  padding: 4rem 0 3rem;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.channel-header {
  display: flex;
  align-items: center;
  gap: 2rem;
  max-width: 960px;
  margin: 0 auto;
  flex-wrap: wrap;
}

.channel-avatar {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF0000, #cc0000);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 0 30px rgba(255,0,0,0.3);
}

.channel-info { flex: 1; }

.channel-label {
  display: block;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #FF0000;
  margin-bottom: 0.35rem;
}

.channel-info h1 {
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 800;
  color: white;
  margin: 0 0 0.3rem;
}

.channel-tagline {
  color: rgba(255,255,255,0.65);
  font-size: 0.9rem;
  margin-bottom: 0.75rem;
}

.channel-meta {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.55);

  svg { opacity: 0.7; }
}

.channel-cta {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  flex-shrink: 0;
}

.btn-subscribe {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.75rem 1.5rem;
  background: #FF0000;
  color: white;
  border-radius: 8px;
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
  transition: all 0.25s ease;
  box-shadow: 0 4px 15px rgba(255,0,0,0.35);

  &:hover {
    background: #cc0000;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255,0,0,0.45);
  }
}

.btn-view-all {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.65rem 1.25rem;
  background: transparent;
  color: rgba(255,255,255,0.75);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 8px;
  font-weight: 600;
  font-size: 0.85rem;
  text-decoration: none;
  transition: all 0.25s ease;

  &:hover {
    color: white;
    border-color: rgba(255,255,255,0.5);
  }
}

/* ===== STATS STRIP ===== */
.yt-stats-strip {
  background: #111;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}

.yt-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  padding: 1.25rem 0;
  flex-wrap: wrap;
}

.yt-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.2rem;
}

.ys-num {
  font-size: 1.4rem;
  font-weight: 800;
  color: #FF0000;
  line-height: 1;
}

.ys-lbl {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.5);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.yt-div {
  width: 1px;
  height: 30px;
  background: rgba(255,255,255,0.1);
}

/* ===== FEATURED VIDEO ===== */
.featured-video-section {
  padding: 5rem 0;
  background: var(--color-bg);
}

.featured-layout {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 3rem;
  align-items: start;
  margin-top: 2.5rem;
}

.video-embed-wrap {
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,0.2);
}

.video-embed {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;

  iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: none;
    border-radius: 16px;
  }
}

.featured-info {
  padding-top: 0.5rem;
}

.video-category {
  display: inline-block;
  background: rgba(255,0,0,0.1);
  color: #FF0000;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  padding: 0.25rem 0.75rem;
  border-radius: 20px;
  margin-bottom: 0.75rem;
}

.featured-info h3 {
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--color-text-primary);
  line-height: 1.35;
  margin-bottom: 1rem;
}

.featured-info p {
  color: var(--color-text-secondary, #666);
  line-height: 1.75;
  font-size: 0.95rem;
  margin-bottom: 1.25rem;
}

.video-topics {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}

.vtag {
  background: var(--color-bg-secondary, #f3f4f6);
  color: var(--color-text-secondary, #555);
  font-size: 0.78rem;
  font-weight: 600;
  padding: 0.28rem 0.7rem;
  border-radius: 20px;
}

.btn-watch {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  background: #FF0000;
  color: white;
  border-radius: 8px;
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
  transition: all 0.25s ease;
  box-shadow: 0 4px 15px rgba(255,0,0,0.25);

  &:hover {
    background: #cc0000;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255,0,0,0.35);
  }
}

/* ===== TOPICS ===== */
.channel-topics-section {
  padding: 5rem 0;
  background: var(--color-bg-secondary);
}

.topics-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-top: 2.5rem;
}

.topic-card-yt {
  background: var(--color-bg);
  border: 1px solid var(--color-border, rgba(0,0,0,0.08));
  border-radius: 16px;
  padding: 1.75rem;
  transition: all 0.25s ease;

  &:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 35px rgba(0,0,0,0.1);
    border-color: rgba(255,0,0,0.2);
  }

  h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0.75rem 0 0.5rem;
  }

  p {
    font-size: 0.85rem;
    color: var(--color-text-secondary, #666);
    line-height: 1.65;
    margin: 0;
  }
}

.tc-icon {
  font-size: 1.75rem;
  width: 52px;
  height: 52px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;

  &.tc-jung     { background: rgba(139,92,246,0.1); }
  &.tc-neuro    { background: rgba(59,130,246,0.1); }
  &.tc-manifest { background: rgba(245,158,11,0.1); }
  &.tc-stoic    { background: rgba(16,185,129,0.1); }
  &.tc-habit    { background: rgba(102,126,234,0.1); }
  &.tc-success  { background: rgba(255,0,0,0.08); }
}

/* ===== CTA ===== */
.yt-cta-section {
  padding: 5rem 0;
  background: var(--color-bg);
}

.yt-cta-card {
  background: linear-gradient(135deg, #0f0f0f 0%, #1a1a2e 100%);
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,0.2);
}

.yt-cta-content {
  padding: 3.5rem;
  text-align: center;
}

.yt-logo-big {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 90px;
  height: 90px;
  background: rgba(255,255,255,0.08);
  border-radius: 20px;
  margin-bottom: 1.5rem;
}

.yt-cta-content h2 {
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 800;
  color: white;
  margin-bottom: 1rem;
}

.yt-cta-content p {
  color: rgba(255,255,255,0.7);
  font-size: 1rem;
  line-height: 1.75;
  max-width: 550px;
  margin: 0 auto 2rem;
}

.cta-buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

.btn-subscribe-big {
  display: inline-flex;
  align-items: center;
  padding: 0.9rem 2rem;
  background: #FF0000;
  color: white;
  border-radius: 50px;
  font-weight: 700;
  font-size: 1rem;
  text-decoration: none;
  transition: all 0.3s ease;
  box-shadow: 0 4px 20px rgba(255,0,0,0.35);

  &:hover {
    background: #cc0000;
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(255,0,0,0.5);
  }
}

.btn-read-more {
  display: inline-flex;
  align-items: center;
  padding: 0.9rem 2rem;
  background: transparent;
  color: rgba(255,255,255,0.8);
  border: 2px solid rgba(255,255,255,0.25);
  border-radius: 50px;
  font-weight: 700;
  font-size: 1rem;
  text-decoration: none;
  transition: all 0.3s ease;

  &:hover {
    color: white;
    border-color: rgba(255,255,255,0.6);
  }
}

/* ===== SHARED ===== */
.section-header {
  text-align: center;
  margin-bottom: 1rem;

  h2 { margin-bottom: 0.75rem; }
  p {
    color: var(--color-text-secondary, #666);
    max-width: 580px;
    margin: 0 auto;
    font-size: 1.02rem;
    line-height: 1.7;
  }
}

.section-badge {
  display: inline-block;
  background: rgba(255,0,0,0.08);
  border: 1px solid rgba(255,0,0,0.15);
  color: #FF0000;
  font-size: 0.82rem;
  font-weight: 700;
  padding: 0.35rem 1rem;
  border-radius: 50px;
  margin-bottom: 0.75rem;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .featured-layout {
    grid-template-columns: 1fr;
  }
  .channel-header {
    flex-direction: column;
    text-align: center;
  }
  .channel-cta {
    flex-direction: row;
    justify-content: center;
  }
  .channel-meta { justify-content: center; }
}

@media (max-width: 600px) {
  .yt-hero { padding: 3rem 0 2rem; }
  .yt-cta-content { padding: 2.5rem 1.5rem; }
  .channel-cta { flex-direction: column; align-items: center; }
  .yt-stats { gap: 1rem; }
  .yt-div { display: none; }
}
</style>
