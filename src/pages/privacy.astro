---
import Layout from "../layouts/Layout.astro";

const pageTitle = "Privacy Policy — Success Odyssey Hub";
const pageDescription = "Privacy Policy for successodysseyhub.com. How we collect, use, and protect your information including our use of Google AdSense and Amazon affiliate links.";
const pageKeywords = "privacy policy successodysseyhub, data privacy";
const lastUpdated = "March 22, 2026";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  type="website"
  noindex={false}
  canonicalUrl="https://successodysseyhub.com/privacy"
>

  <section class="legal-hero">
    <div class="container">
      <h1>Privacy Policy</h1>
      <p class="last-updated">Last updated: {lastUpdated}</p>
    </div>
  </section>

  <section class="legal-content">
    <div class="container">
      <div class="legal-layout">

        <article class="legal-body">

          <section class="legal-section">
            <h2>1. Introduction</h2>
            <p>
              Welcome to Success Odyssey Hub ("we," "our," or "us"). We operate the website at <strong>https://successodysseyhub.com</strong> (the "Site"). This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our Site. Please read this carefully. If you disagree with its terms, please discontinue use of the Site.
            </p>
          </section>

          <section class="legal-section">
            <h2>2. Information We Collect</h2>
            <h3>Automatically Collected Information</h3>
            <p>When you visit the Site, certain information is collected automatically, including:</p>
            <ul>
              <li>IP address and approximate geographic location</li>
              <li>Browser type and version</li>
              <li>Operating system</li>
              <li>Pages visited and time spent on each page</li>
              <li>Referring URL (the page you visited before ours)</li>
              <li>Date and time of your visit</li>
            </ul>

            <h3>Information You Provide</h3>
            <p>
              We may collect information you provide directly, such as when you contact us through our contact form — including your name and email address.
            </p>
          </section>

          <section class="legal-section">
            <h2>3. How We Use Your Information</h2>
            <p>We use the information we collect to:</p>
            <ul>
              <li>Operate, maintain, and improve the Site</li>
              <li>Understand how visitors use the Site and which content is most valuable</li>
              <li>Respond to your questions and messages</li>
              <li>Monitor and analyze usage patterns to improve user experience</li>
              <li>Comply with legal obligations</li>
            </ul>
          </section>

          <section class="legal-section">
            <h2>4. Google AdSense and Advertising</h2>
            <p>
              We use <strong>Google AdSense</strong> to display advertisements on our Site. Google AdSense uses cookies and similar technologies to serve ads based on your prior visits to our Site and other websites.
            </p>
            <p>
              Google's use of advertising cookies enables it and its partners to serve ads based on your visit to our Site and other sites on the internet. You may opt out of personalized advertising by visiting <a href="https://www.google.com/settings/ads" target="_blank" rel="nofollow noopener noreferrer">Google Ads Settings</a>.
            </p>
            <p>
              For more information on how Google uses data when you use partner sites, visit: <a href="https://policies.google.com/technologies/partner-sites" target="_blank" rel="nofollow noopener noreferrer">policies.google.com/technologies/partner-sites</a>
            </p>
            <p>Our Google AdSense Publisher ID: <strong>ca-pub-7229511013815291</strong></p>
          </section>

          <section class="legal-section">
            <h2>5. Affiliate Disclosure</h2>
            <p>
              Some articles on this Site contain <strong>affiliate links</strong>, primarily through the <strong>Amazon Associates</strong> program. If you click an affiliate link and make a qualifying purchase, we may earn a small commission at no additional cost to you.
            </p>
            <p>
              As an Amazon Associate, we earn from qualifying purchases. We only recommend products and books we believe are genuinely useful to our readers. Affiliate relationships do not influence our editorial content or recommendations.
            </p>
            <p>
              Affiliate links are clearly used in context (typically as book recommendations). The presence of affiliate links does not mean we were paid to endorse the linked content.
            </p>
          </section>

          <section class="legal-section">
            <h2>6. Cookies</h2>
            <p>
              Our Site uses cookies — small text files stored on your device — to improve your experience and enable certain functionality. Types of cookies used include:
            </p>
            <ul>
              <li><strong>Essential cookies:</strong> Required for the Site to function properly.</li>
              <li><strong>Analytics cookies:</strong> Help us understand how visitors interact with the Site.</li>
              <li><strong>Advertising cookies:</strong> Used by Google AdSense to deliver relevant advertisements.</li>
            </ul>
            <p>
              You can control cookies through your browser settings. Note that disabling certain cookies may affect the functionality of the Site or the relevance of advertisements displayed.
            </p>
          </section>

          <section class="legal-section">
            <h2>7. Third-Party Services</h2>
            <p>Our Site uses the following third-party services, each with their own privacy practices:</p>
            <ul>
              <li><strong>Google AdSense</strong> — advertising: <a href="https://policies.google.com/privacy" target="_blank" rel="nofollow noopener noreferrer">Google Privacy Policy</a></li>
              <li><strong>Google Analytics / Google Tag Manager</strong> — analytics: <a href="https://policies.google.com/privacy" target="_blank" rel="nofollow noopener noreferrer">Google Privacy Policy</a></li>
              <li><strong>Amazon Associates</strong> — affiliate program: <a href="https://www.amazon.com/gp/help/customer/display.html?nodeId=468496" target="_blank" rel="nofollow noopener noreferrer">Amazon Privacy Notice</a></li>
            </ul>
            <p>We are not responsible for the privacy practices of these third parties.</p>
          </section>

          <section class="legal-section">
            <h2>8. Data Retention</h2>
            <p>
              We retain automatically collected data only as long as necessary to fulfill the purposes outlined in this policy, unless a longer period is required by law. Contact form submissions are retained only as long as needed to respond to your inquiry.
            </p>
          </section>

          <section class="legal-section">
            <h2>9. Children's Privacy</h2>
            <p>
              Our Site is not directed to children under the age of 13. We do not knowingly collect personal information from children under 13. If you believe your child has provided us with personal information, please contact us and we will delete it promptly.
            </p>
          </section>

          <section class="legal-section">
            <h2>10. Your Rights</h2>
            <p>Depending on your location, you may have rights including:</p>
            <ul>
              <li>The right to access personal information we hold about you</li>
              <li>The right to request correction of inaccurate information</li>
              <li>The right to request deletion of your personal information</li>
              <li>The right to opt out of certain data processing</li>
            </ul>
            <p>To exercise any of these rights, contact us using the details in Section 12.</p>
          </section>

          <section class="legal-section">
            <h2>11. California Privacy Rights (CCPA)</h2>
            <p>
              If you are a California resident, you have rights under the California Consumer Privacy Act (CCPA), including the right to know what personal information is collected, the right to request deletion, and the right to opt out of the sale of personal information. <strong>We do not sell personal information.</strong> To exercise your CCPA rights, please contact us.
            </p>
          </section>

          <section class="legal-section">
            <h2>12. Contact Us</h2>
            <p>If you have questions about this Privacy Policy or our data practices, please contact us:</p>
            <div class="contact-info-block">
              <p><strong>Success Odyssey Hub</strong></p>
              <p>Website: <a href="https://successodysseyhub.com">successodysseyhub.com</a></p>
              <p>Contact form: <a href="/contact">successodysseyhub.com/contact</a></p>
            </div>
          </section>

          <section class="legal-section">
            <h2>13. Changes to This Policy</h2>
            <p>
              We may update this Privacy Policy at any time. We will indicate the date of the most recent update at the top of this page. Your continued use of the Site after any changes constitutes acceptance of the updated policy.
            </p>
          </section>

        </article>

        <aside class="legal-sidebar">
          <div class="sidebar-nav">
            <h3>Sections</h3>
            <nav>
              <a href="#introduction">1. Introduction</a>
              <a href="#information">2. Information We Collect</a>
              <a href="#use">3. How We Use It</a>
              <a href="#adsense">4. Google AdSense</a>
              <a href="#affiliate">5. Affiliate Disclosure</a>
              <a href="#cookies">6. Cookies</a>
              <a href="#third-party">7. Third Parties</a>
              <a href="#retention">8. Data Retention</a>
              <a href="#children">9. Children's Privacy</a>
              <a href="#rights">10. Your Rights</a>
              <a href="#ccpa">11. CCPA</a>
              <a href="#contact">12. Contact</a>
              <a href="#changes">13. Changes</a>
            </nav>
          </div>

          <div class="sidebar-links">
            <h3>Related</h3>
            <a href="/terms">Terms of Service →</a>
            <a href="/contact">Contact Us →</a>
          </div>
        </aside>

      </div>
    </div>
  </section>

</Layout>

<style lang="scss">
.legal-hero {
  background: var(--color-bg-secondary);
  border-bottom: 1px solid var(--color-border);
  padding: var(--spacing-2xl) 0 var(--spacing-xl);

  h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-primary);
  }

  .last-updated {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }
}

.legal-content {
  padding: var(--spacing-3xl) 0;
}

.legal-layout {
  display: grid;
  grid-template-columns: 1fr 220px;
  gap: var(--spacing-3xl);
  align-items: start;
}

.legal-body {
  .legal-section {
    margin-bottom: var(--spacing-3xl);
    padding-bottom: var(--spacing-2xl);
    border-bottom: 1px solid var(--color-border);

    &:last-child {
      border-bottom: none;
    }

    h2 {
      font-size: 1.3rem;
      color: var(--color-text-primary);
      margin-bottom: var(--spacing-lg);
    }

    h3 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--color-text-primary);
      margin: var(--spacing-xl) 0 var(--spacing-md);
    }

    p {
      color: var(--color-text-secondary);
      line-height: 1.8;
      margin-bottom: var(--spacing-md);
      font-size: 0.975rem;

      &:last-child { margin-bottom: 0; }
    }

    ul {
      padding-left: var(--spacing-xl);
      margin-bottom: var(--spacing-md);

      li {
        color: var(--color-text-secondary);
        line-height: 1.8;
        margin-bottom: var(--spacing-sm);
        font-size: 0.975rem;
      }
    }

    a {
      color: var(--color-primary);
      font-weight: 600;
      &:hover { text-decoration: underline; }
    }

    strong {
      color: var(--color-text-primary);
    }
  }
}

.contact-info-block {
  background: var(--color-bg-secondary);
  border-radius: var(--radius);
  padding: var(--spacing-lg) var(--spacing-xl);
  border-left: 3px solid var(--color-primary);
  margin-top: var(--spacing-md);

  p {
    margin-bottom: var(--spacing-sm) !important;
    &:last-child { margin-bottom: 0 !important; }
  }
}

.legal-sidebar {
  position: sticky;
  top: 90px;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-lg);
}

.sidebar-nav {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);

  h3 {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-border);
  }

  nav {
    display: flex;
    flex-direction: column;
    gap: 2px;

    a {
      font-size: 0.8rem;
      color: var(--color-text-secondary);
      text-decoration: none;
      padding: 4px 0;
      transition: var(--transition);
      line-height: 1.5;

      &:hover {
        color: var(--color-primary);
        padding-left: 4px;
      }
    }
  }
}

.sidebar-links {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);

  h3 {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-border);
  }

  a {
    display: block;
    font-size: 0.875rem;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--color-border);

    &:last-child { border-bottom: none; }
    &:hover { text-decoration: underline; }
  }
}

@media (max-width: 900px) {
  .legal-layout {
    grid-template-columns: 1fr;
  }

  .legal-sidebar {
    position: static;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 600px) {
  .legal-sidebar {
    grid-template-columns: 1fr;
  }
}
</style>